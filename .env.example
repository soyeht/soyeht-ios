# Copy this file to `.env.local` and fill in the values for your machine.
# `.env.local` is ignored by git.

# Backend target for QA scripts.
SOYEHT_BASE_URL=http://127.0.0.1:8892
QA_BASE_URL=

# Optional auth/session fixtures. Leave blank to auto-discover when possible.
SOYEHT_TOKEN=
SOYEHT_CONTAINER=
SOYEHT_SESSION=

# SSH host used to mint pair tokens for remote QA targets.
SOYEHT_SSH_HOST=

# Appium / device config.
APPIUM_URL=http://127.0.0.1:4723
SOYEHT_IOS_UDID=
SOYEHT_BUNDLE_ID=com.soyeht.app
SOYEHT_QA_RUN_DIR=

# WebDriverAgent config.
SOYEHT_WDA_URL=
SOYEHT_WDA_XCODEPROJ=
SOYEHT_WDA_TEAM_ID=
SOYEHT_WDA_BUNDLE_ID=com.soyeht.WebDriverAgentRunner
SOYEHT_WDA_SIGNING_ID=Apple Development

# Remote VM / fixture paths used by live Appium suites.
SOYEHT_REMOTE_HOME=/home/qa
SOYEHT_FIRECRACKER_STATE_DIR=/home/qa/firecracker/instances
SOYEHT_VM_ROOTFS=
SOYEHT_LARGE_VIDEO_BACKUP_PATH=/root/Downloads/0-large-video.qa-bak

# Test toggles.
SOYEHT_UI_TEST_FORCE_BROWSER_FALLBACK=0
SOYEHT_QA_MAC_NAME=mac-host

# Product A mobile Claw VPN DEV control-plane E2E.
# Keep real IDs/endpoints only in `.env.local` or `.env.*.local`, never in git.
SOYEHT_RUN_MOBILE_CLAW_VPN_DEV_E2E_PREFLIGHT=0
SOYEHT_RUN_MOBILE_CLAW_VPN_DEV_E2E=0
SOYEHT_MOBILE_CLAW_VPN_EVIDENCE_DIR=
SOYEHT_MOBILE_CLAW_VPN_BUNDLE_ID=com.soyeht.app.dev
SOYEHT_MOBILE_CLAW_VPN_DEVICE_ID=
SOYEHT_MOBILE_CLAW_VPN_CLAW_ID=
SOYEHT_MOBILE_CLAW_VPN_DEVICE_ALIAS=Device-D
SOYEHT_MOBILE_CLAW_VPN_CLAW_ALIAS=Claw-M
SOYEHT_MOBILE_CLAW_VPN_RELAY_ALIAS=Relay-R
SOYEHT_MOBILE_CLAW_VPN_MESH_ALIAS=Mesh-C
