TOOL_HANDLERS = {
    "open_panes": tool_open_panes,
    "open_shell": tool_open_shell,
    "open_file": tool_open_file,
    "open_workspace": tool_open_workspace,
    "create_worktree_panes": tool_create_worktree_panes,
    "agent_race_panes": tool_agent_race_panes,
    "send_pane_input": tool_send_pane_input,
    "rename_panes": tool_rename_panes,
    "rename_workspace": tool_rename_workspace,
    "arrange_panes": tool_arrange_panes,
    "emphasize_pane": tool_emphasize_pane,
}


class StdioTransport:
    def __init__(self):
        self.framed = None

    def read_messages(self):
        stream = sys.stdin.buffer
        while True:
            line = stream.readline()
            if not line:
                return
            if not line.strip():
                continue

            if line.lower().startswith(b"content-length:"):
                self.framed = True
                length = int(line.split(b":", 1)[1].strip())
                while True:
                    header = stream.readline()
                    if not header or header in (b"\r\n", b"\n"):
                        break
                    if header.lower().startswith(b"content-length:"):
                        length = int(header.split(b":", 1)[1].strip())
                body = stream.read(length)
                if not body:
                    return
                yield json.loads(body.decode("utf-8"))
            else:
                if self.framed is None:
                    self.framed = False
                yield json.loads(line.decode("utf-8"))

    def write_message(self, message):
        body = json.dumps(message, separators=(",", ":"), ensure_ascii=False).encode("utf-8")
        if self.framed:
            sys.stdout.buffer.write(f"Content-Length: {len(body)}\r\n\r\n".encode("ascii"))
            sys.stdout.buffer.write(body)
        else:
            sys.stdout.buffer.write(body + b"\n")
        sys.stdout.buffer.flush()


def response(message_id, result):
    return {
        "jsonrpc": "2.0",
        "id": message_id,
        "result": result,
    }


def error_response(message_id, code, message):
    return {
        "jsonrpc": "2.0",
        "id": message_id,
        "error": {
            "code": code,
            "message": message,
        },
    }


def tool_result(value, is_error=False):
    return {
        "content": [
            {
                "type": "text",
                "text": json.dumps(value, indent=2, sort_keys=True),
            }
        ],
        "isError": is_error,
    }


def handle_message(message):
    message_id = message.get("id")
    method = message.get("method")
    params = message.get("params") or {}

    if method in ("notifications/initialized", "$/cancelRequest"):
        return None

    if method == "initialize":
        protocol = params.get("protocolVersion", "2024-11-05")
        return response(message_id, {
            "protocolVersion": protocol,
            "capabilities": {
                "tools": {
                    "listChanged": False,
                },
            },
            "serverInfo": {
                "name": SERVER_NAME,
                "version": SERVER_VERSION,
            },
        })

    if method == "ping":
        return response(message_id, {})

    if method == "tools/list":
        return response(message_id, {"tools": TOOLS})

    if method == "tools/call":
        name = params.get("name")
        arguments = params.get("arguments") or {}
        handler = TOOL_HANDLERS.get(name)
        if handler is None:
            return response(message_id, tool_result({"error": f"Unknown tool: {name}"}, is_error=True))
        try:
            return response(message_id, tool_result(handler(arguments)))
        except Exception as exc:
            print(f"{SERVER_NAME}: tool {name} failed: {exc}", file=sys.stderr)
            return response(message_id, tool_result({"error": str(exc)}, is_error=True))

    if message_id is None:
        return None
    return error_response(message_id, -32601, f"Method not found: {method}")


def main():
    transport = StdioTransport()
    for message in transport.read_messages():
        try:
            reply = handle_message(message)
        except Exception as exc:
            print(f"{SERVER_NAME}: request failed: {exc}", file=sys.stderr)
            reply = error_response(message.get("id"), -32603, str(exc))
        if reply is not None:
            transport.write_message(reply)


if __name__ == "__main__":
    main()
