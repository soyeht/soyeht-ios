            "value": "¿Emparejar este iPhone con el Mac?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appairer cet iPhone avec ce Mac ?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस iPhone को Mac से पेयर करें?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasangkan iPhone ini dengan Mac?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone を Mac にペアリングしますか？"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "이 iPhone을 Mac과 페어링할까요?"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "将这部 iPhone 与 Mac 配对？"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "हा iPhone Mac शी जोडायचा?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Parear este iPhone com o Mac?"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Emparelhar este iPhone com o Mac?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
