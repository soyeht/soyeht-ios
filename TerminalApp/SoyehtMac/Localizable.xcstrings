      "comment": "Benchmark failure alert body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Need an active main window with at least 2 workspaces. Check Console.app for [bench] messages."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "É necessária uma janela principal ativa com pelo menos 2 áreas de trabalho. Verifique as mensagens [bench] no Console.app."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "É necessária uma janela principal ativa com pelo menos 2 áreas de trabalho. Verifique as mensagens [bench] no Console.app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se necesita una ventana principal activa con al menos 2 espacios de trabajo. Revisa Console.app para ver mensajes [bench]."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein aktives Hauptfenster mit mindestens 2 Arbeitsbereichen ist erforderlich. Prüfen Sie Console.app auf [bench]-Meldungen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fenêtre principale active avec au moins 2 espaces de travail est nécessaire. Consultez Console.app pour les messages [bench]."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нужно активное главное окно минимум с 2 рабочими областями. Проверьте сообщения [bench] в Console.app."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Perlu jendela utama aktif dengan minimal 2 workspace. Periksa pesan [bench] di Console.app."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحتاج إلى نافذة رئيسية نشطة تحتوي على مساحتَي عمل على الأقل. راجع Console.app لرسائل [bench]."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کم از کم 2 workspaces والی active main window چاہیے۔ [bench] messages کے لیے Console.app check کریں۔"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "少なくとも 2 つのワークスペースを持つアクティブなメインウィンドウが必要です。[bench] メッセージは Console.app で確認してください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "워크스페이스가 2개 이상 있는 활성 메인 창이 필요합니다. [bench] 메시지는 Console.app에서 확인하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "需要一个至少包含 2 个工作区的活动主窗口。请在 Console.app 中查看 [bench] 消息。"}},
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कम से कम 2 workspaces वाली active main window चाहिए। [bench] messages के लिए Console.app check करें।"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Need an active main window with at least 2 workspaces. Check Console.app for [bench] messages."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Need an active main window with at least 2 workspaces. Check Console.app for [bench] messages."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Need an active main window with at least 2 workspaces. Check Console.app for [bench] messages."
          }
        }
      }
    },
