    "pairing.alert.revokeOne.message": {
      "comment": "Confirm alert body — consequence of revoking a single device.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لن يتمكن هذا الـ iPhone من فتح panes على هذا الـ Mac بدون اقتران جديد."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "নতুন পেয়ারিং ছাড়া এই iPhone এই Mac-এ pane খুলতে পারবে না।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses iPhone kann auf diesem Mac keine Panes mehr öffnen, bis eine neue Kopplung erfolgt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This iPhone will no longer be able to open panes on this Mac without a fresh pairing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ese iPhone ya no podrá abrir panes en este Mac sin un emparejamiento nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet iPhone ne pourra plus ouvrir de pane sur ce Mac sans un nouvel appairage."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह iPhone नए पेयरिंग के बिना इस Mac पर pane नहीं खोल सकेगा।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone ini tidak akan bisa membuka pane di Mac ini tanpa pemasangan baru."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone は再ペアリングしないと、この Mac で pane を開けなくなります。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "नवीन जोडणीशिवाय हा iPhone या Mac वर panes उघडू शकणार नाही."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esse iPhone não poderá mais abrir panes deste Mac sem um novo pareamento."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Esse iPhone não poderá mais abrir panes deste Mac sem um novo emparelhamento."
          }
