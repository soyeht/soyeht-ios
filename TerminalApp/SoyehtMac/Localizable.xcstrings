    "installer.mode.tailscale.description": {
      "comment": "Install-mode description — Tailscale-based remote access. Requires Tailscale app installed.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وصول آمن من iPhone أو iPad أو أجهزة Mac أخرى عبر Tailscale. يتطلب تطبيق Tailscale مثبتًا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Tailscale এর মাধ্যমে iPhone, iPad বা অন্যান্য Mac থেকে নিরাপদ অ্যাক্সেস। Tailscale অ্যাপ ইনস্টল থাকা আবশ্যক।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sicherer Zugriff von iPhone, iPad oder anderen Macs über Tailscale. Benötigt die installierte Tailscale-App."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Secure access from iPhone, iPad, or other Macs via Tailscale. Requires the Tailscale app installed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acceso seguro desde iPhone, iPad u otros Mac a través de Tailscale. Requiere la app Tailscale instalada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accès sécurisé depuis iPhone, iPad ou d’autres Mac via Tailscale. Nécessite l’app Tailscale installée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale के ज़रिये iPhone, iPad या अन्य Mac से सुरक्षित पहुँच। Tailscale ऐप इंस्टॉल होना चाहिए।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses aman dari iPhone, iPad, atau Mac lain melalui Tailscale. Membutuhkan aplikasi Tailscale terpasang."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone、iPad、または他の Mac から Tailscale 経由で安全にアクセス。Tailscale アプリのインストールが必要です。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Tailscale मार्गे iPhone, iPad किंवा इतर Macs वरून सुरक्षित प्रवेश. Tailscale अ‍ॅप स्थापित असणे आवश्यक."
          }
        },
        "pt-BR": {
          "stringUnit": {
