    "welcome.uninstall.header.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمسح هذا تثبيت Soyeht بالكامل: صيغة Homebrew، إعدادات ~/.soyeht، صور VM، السجلات، ويفصل كل خادم مقترن في هذا التطبيق."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এটি Soyeht ইনস্টলকে সম্পূর্ণরূপে মুছে দেয়: Homebrew ফর্মুলা, ~/.soyeht কনফিগ, VM ইমেজ, লগ, এবং এই অ্যাপে যুক্ত প্রতিটি সার্ভার সংযোগ বিচ্ছিন্ন করে।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies entfernt die Soyeht-Installation vollständig: Homebrew-Formel, ~/.soyeht-Konfiguration, VM-Images, Logs, und trennt jeden in dieser App gekoppelten Server."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This wipes the Soyeht install end-to-end: Homebrew formula, ~/.soyeht config, VM images, logs, and disconnects every server paired in this app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto borra la instalación de Soyeht por completo: la fórmula de Homebrew, la configuración de ~/.soyeht, las imágenes de VM, los logs, y desconecta cada máquina emparejada en esta app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela efface complètement l’installation de Soyeht : formule Homebrew, configuration ~/.soyeht, images VM, logs, et déconnecte chaque serveur appairé dans cette app."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह Soyeht इंस्टॉल को पूरी तरह से मिटाता है: Homebrew फ़ॉर्मूला, ~/.soyeht कॉन्फ़िग, VM इमेज, लॉग, और इस ऐप में जोड़े गए हर सर्वर को डिस्कनेक्ट करता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini menghapus instalasi Soyeht secara menyeluruh: formula Homebrew, konfigurasi ~/.soyeht, image VM, log, dan memutuskan setiap server yang dipasangkan di app ini."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これは Soyeht のインストールを完全に消去します: Homebrew フォーミュラ、~/.soyeht 設定、VM イメージ、ログ、そしてこのアプリでペアリングされたすべてのサーバーを切断します。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "Soyeht 설치를 끝까지 모두 삭제합니다: Homebrew formula, ~/.soyeht 설정, VM 이미지, 로그, 그리고 이 앱에서 페어링된 모든 서버 연결을 끊습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "这会完整清除 Soyeht 安装：Homebrew formula、~/.soyeht 配置、VM 镜像、日志，并断开此应用中配对的所有服务器。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "हे Soyeht इन्स्टॉल पूर्णपणे पुसून टाकते: Homebrew फॉर्म्युला, ~/.soyeht कॉन्फिग, VM इमेजेस, लॉग, आणि या अॅपमध्ये जोडलेला प्रत्येक सर्व्हर डिस्कनेक्ट करते."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso apaga a instalação do Soyeht de ponta a ponta: fórmula do Homebrew, configuração ~/.soyeht, imagens de VM, logs, e desconecta cada máquina pareada neste app."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto apaga a instalação do Soyeht de ponta a ponta: fórmula do Homebrew, configuração ~/.soyeht, imagens de VM, registos, e desliga cada máquina emparelhada nesta app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это полностью удаляет установку Soyeht: формулу Homebrew, конфигурацию ~/.soyeht, образы VM, журналы, и отключает каждый сопряжённый с этим приложением сервер."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఇది Soyeht ఇన్‌స్టాల్‌ను పూర్తిగా తొలగిస్తుంది: Homebrew ఫార్ములా, ~/.soyeht కాన్ఫిగ్, VM ఇమేజ్‌లు, లాగ్‌లు, మరియు ఈ యాప్‌లో జోడించిన ప్రతి సర్వర్‌ను డిస్‌కనెక్ట్ చేస్తుంది."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ Soyeht کی تنصیب کو مکمل طور پر مٹا دیتا ہے: Homebrew فارمولا، ~/.soyeht کنفگ، VM امیجز، لاگز، اور اس ایپ میں جوڑے گئے ہر سرور کو منقطع کرتا ہے۔"
          }
        }
      },
      "comment": "Header subtitle explaining what the uninstall flow does."
    },
