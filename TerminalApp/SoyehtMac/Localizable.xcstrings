    "appMenu.logout.alert.message": {
      "comment": "Logout confirmation alert body.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي ذلك إلى إزالة جلستك. ستحتاج إلى إدخال host و token مرة أخرى لإعادة الاتصال."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "এটি আপনার সেশন সরিয়ে দেবে। পুনরায় সংযুক্ত হতে host এবং token আবার দিতে হবে।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch wird Ihre Sitzung entfernt. Sie müssen Host und Token erneut eingeben, um sich wieder zu verbinden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will remove your session. You'll need to enter your host and token again to reconnect."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará tu sesión. Tendrás que volver a ingresar host y token para reconectar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera votre session. Vous devrez saisir à nouveau l’hôte et le jeton pour vous reconnecter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह आपका सत्र हटा देगा। पुनः कनेक्ट करने के लिए host और token फिर से दर्ज करना होगा।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tindakan ini akan menghapus sesi Anda. Anda perlu memasukkan host dan token lagi untuk terhubung kembali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションが削除されます。再接続するには host と token を再入力する必要があります。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "यामुळे तुमचे सत्र काढून टाकले जाईल. पुन्हा कनेक्ट करण्यासाठी host आणि token पुन्हा प्रविष्ट करावे लागेल."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto removerá sua sessão. Você precisará informar host e token novamente para reconectar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto removerá a sua sessão. Precisará de introduzir host e token novamente para voltar a ligar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это удалит вашу сессию. Для повторного подключения потребуется ввести host и token заново."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
