    "pairing.empty.message": {
      "comment": "Empty-state message shown when no iPhones are paired yet.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم إقران أي iPhone بعد. اضغط على زر QR في pane وامسحه بتطبيق Soyeht iOS."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "এখনও কোনো iPhone পেয়ার নয়। একটি pane-এ QR বোতামে ট্যাপ করুন এবং Soyeht iOS অ্যাপ দিয়ে স্ক্যান করুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch kein iPhone gekoppelt. Tippen Sie auf die QR-Taste eines Panes und scannen Sie sie mit der Soyeht-iOS-App."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No iPhone paired yet. Tap the QR button on a pane and scan it with the Soyeht iOS app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay iPhone emparejado. Haz clic en el botón QR de un pane y escanéalo con la app Soyeht iOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun iPhone appairé pour l’instant. Cliquez sur le bouton QR d’un pane et scannez-le avec l’app Soyeht iOS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी कोई iPhone पेयर नहीं। किसी pane के QR बटन पर टैप करके Soyeht iOS ऐप से स्कैन करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Belum ada iPhone yang dipasangkan. Ketuk tombol QR pada pane dan pindai dengan aplikasi Soyeht iOS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだペア済みの iPhone はありません。pane の QR ボタンをタップして Soyeht iOS アプリでスキャンしてください。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "अजून कोणताही iPhone जोडलेला नाही. pane च्या QR बटणावर टॅप करा आणि Soyeht iOS अ‍ॅपने स्कॅन करा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum iPhone pareado ainda. Clique no botão QR de um pane e escaneie com o app Soyeht iOS."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum iPhone emparelhado ainda. Clique no botão QR de um pane e leia-o na aplicação Soyeht iOS."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пока нет сопряжённых iPhone. Нажмите кнопку QR на pane и отсканируйте её приложением Soyeht для iOS."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ఇంకా ఏ iPhone జత చేయబడలేదు. ఏదైనా pane లో QR బటన్‌ను నొక్కి Soyeht iOS యాప్‌తో స్కాన్ చేయండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ابھی کوئی iPhone جوڑی شدہ نہیں۔ pane پر QR بٹن دبائیں اور Soyeht iOS ایپ سے اسکین کریں۔"
          }
        }
      }
    },
