    "uninstaller.error.homebrewMissing": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew غير متاح، ولا يوجد شيء متبقٍ للتطبيق لإزالته."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew উপলব্ধ নেই, এবং অ্যাপটির অপসারণ করার মতো কিছুই অবশিষ্ট নেই।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew ist nicht verfügbar, und für die App gibt es nichts mehr zu entfernen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew is not available, and there is nothing left for the app to remove."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew no está disponible y no queda nada para que la app elimine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew n’est pas disponible et il ne reste plus rien à supprimer pour l’app."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew उपलब्ध नहीं है, और ऐप के लिए हटाने को कुछ भी शेष नहीं है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew tidak tersedia, dan tidak ada yang tersisa untuk dihapus oleh app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew が利用できません。アプリが削除するものは残っていません。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew उपलब्ध नाही, आणि अॅपला काढून टाकण्यासाठी काहीही उरलेले नाही."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Homebrew não está disponível e não há mais nada para o app remover."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O Homebrew não está disponível e não há mais nada para a app remover."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew недоступен, и приложению больше нечего удалять."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew అందుబాటులో లేదు, మరియు యాప్‌కు తొలగించడానికి ఇంకేమీ మిగిలి లేదు."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew دستیاب نہیں ہے، اور ایپ کو ہٹانے کے لیے کچھ باقی نہیں ہے۔"
          }
        }
      },
      "comment": "Uninstall error — brew missing AND no residual state to clean."
    },
