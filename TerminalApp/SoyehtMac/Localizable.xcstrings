    "bootstrap.installPreview.bullet1.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يبقى محرك خفيف يعمل في الخلفية، جاهزًا للرد على الوكلاء."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "A lightweight engine keeps running in the background, ready to answer agents."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine schlanke Engine läuft im Hintergrund weiter und ist bereit, auf Anfragen von Agenten zu reagieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A lightweight engine keeps running in the background, ready to answer agents."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un motor ligero sigue ejecutándose en segundo plano, listo para responder a los agentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un moteur léger continue de fonctionner en arrière-plan, prêt à répondre aux agents."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक lightweight engine background में running रहता है, agents को answer करने के लिए ready."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mesin ringan tetap berjalan di latar belakang, siap menjawab agen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "軽量エンジンがバックグラウンドで動作し続け、エージェントに応答できる状態を保ちます。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "가벼운 엔진이 백그라운드에서 계속 실행되어 에이전트에 응답할 준비를 합니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "轻量引擎会在后台持续运行，随时准备响应智能体。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "A lightweight engine keeps running in the background, ready to answer agents."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um motor leve fica rodando em segundo plano, pronto para responder aos agentes."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Um motor leve continua em execução em segundo plano, pronto para responder aos agentes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Легкий движок продолжает работать в фоне и готов отвечать агентам."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "A lightweight engine keeps running in the background, ready to answer agents."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایک lightweight engine background میں running رہتا ہے، agents کو answer کرنے کے لیے ready."
          }
        }
      },
      "comment": "MA2 bullet 1 detail: describes the background engine."
    },
