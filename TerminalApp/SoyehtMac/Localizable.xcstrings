    "bootstrap.approval.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ليظل Soyeht نشطًا على هذا Mac، فعّله من System Settings > General > Login Items."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "For Soyeht to stay alive on this Mac, enable it in System Settings > General > Login Items."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Damit Soyeht auf diesem Mac aktiv bleibt, aktivieren Sie es unter Systemeinstellungen > Allgemein > Anmeldeobjekte."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For Soyeht to stay alive on this Mac, enable it in System Settings > General > Login Items."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para que Soyeht siga activo en este Mac, actívalo en Ajustes del Sistema > General > Ítems de inicio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour que Soyeht reste actif sur ce Mac, activez-le dans Réglages Système > Général > Ouverture."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Soyeht को इस Mac पर alive रखने के लिए, इसे System Settings > General > Login Items में enable करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Agar Soyeht tetap aktif di Mac ini, aktifkan di System Settings > General > Login Items."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この Mac で Soyeht を動作させ続けるには、システム設定 > 一般 > ログイン項目 で有効にしてください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "이 Mac에서 Soyeht가 계속 실행되도록 하려면 시스템 설정 > 일반 > 로그인 항목에서 활성화하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "为了让 Soyeht 在这台 Mac 上保持运行，请在“系统设置 > 通用 > 登录项”中启用它。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "For Soyeht to stay alive on this Mac, enable it in System Settings > General > Login Items."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para o Soyeht continuar vivo neste Mac, precisamos que você o habilite em Ajustes do Sistema → Geral → Itens de Login."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Para o Soyeht continuar vivo neste Mac, precisamos que o ative em Definições do Sistema → Geral → Itens de início de sessão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
