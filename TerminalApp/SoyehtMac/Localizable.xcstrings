            "value": "Keine theyOS-Server verbunden. Verwenden Sie den theyOS-Installations- oder Verbindungsablauf, um einen hinzuzufügen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No theyOS servers connected. Use the theyOS install or connect flow to add one."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay servidores theyOS conectados. Usa el flujo de instalación o conexión de theyOS para agregar uno."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun serveur theyOS connecté. Utilisez le flux d’installation ou de connexion theyOS pour en ajouter un."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई theyOS servers connected नहीं हैं। एक add करने के लिए theyOS install या connect flow use करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada server theyOS yang terhubung. Gunakan alur instal atau koneksi theyOS untuk menambahkannya."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続済みの theyOS サーバーはありません。追加するには theyOS のインストールまたは接続フローを使用してください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "연결된 theyOS 서버가 없습니다. theyOS 설치 또는 연결 흐름을 사용해 추가하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "没有已连接的 theyOS 服务器。请使用 theyOS 安装或连接流程添加一个。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "No theyOS servers connected. Use the theyOS install or connect flow to add one."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum servidor theyOS conectado. Use o fluxo de instalação ou conexão do theyOS para adicionar um."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não há servidores theyOS ligados. Use o fluxo de instalação ou ligação do theyOS para adicionar um."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет подключенных серверов theyOS. Используйте установку theyOS или поток подключения, чтобы добавить сервер."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "No theyOS servers connected. Use the theyOS install or connect flow to add one."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کوئی theyOS servers connected نہیں ہیں۔ ایک add کرنے کے لیے theyOS install یا connect flow use کریں۔"
          }
        }
      },
      "comment": "Empty-state message shown when no theyOS servers are paired."
    },
