          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "claws が見つかりません"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "claws सापडले नाहीत"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum claws encontrado"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum claws encontrado"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "claws не найдены"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "claws కనుగొనబడలేదు"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کوئی claws نہیں ملا"
          }
        }
      }
    },
