    "autoPair.error.bootstrapTokenMissing": {
      "comment": "Auto-pair error — ~/.soyeht/setup-token missing after install; user should re-run install.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الملف ~/.soyeht/setup-token مفقود. قم بتشغيل التثبيت مرة أخرى."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.soyeht/setup-token ফাইলটি অনুপস্থিত। অনুগ্রহ করে ইনস্টল পুনরায় চালান।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Datei ~/.soyeht/setup-token fehlt. Führen Sie die Installation erneut aus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "File ~/.soyeht/setup-token is missing. Please run the install again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Falta el archivo ~/.soyeht/setup-token. Ejecuta la instalación de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fichier ~/.soyeht/setup-token manquant. Relancez l’installation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल ~/.soyeht/setup-token नहीं है। कृपया इंस्टॉल पुनः चलाएँ।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Berkas ~/.soyeht/setup-token tidak ada. Jalankan instalasi lagi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.soyeht/setup-token ファイルが見つかりません。インストールを再実行してください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "~/.soyeht/setup-token 파일이 없습니다. 설치를 다시 실행하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "缺少 ~/.soyeht/setup-token 文件。请重新运行安装。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "फाईल ~/.soyeht/setup-token गहाळ आहे. कृपया इंस्टॉल पुन्हा चालवा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Arquivo ~/.soyeht/setup-token ausente. Rode a instalação novamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ficheiro ~/.soyeht/setup-token em falta. Execute a instalação novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Файл ~/.soyeht/setup-token отсутствует. Повторите установку."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.soyeht/setup-token ఫైల్ లేదు. దయచేసి ఇన్‌స్టాల్‌ను మళ్ళీ అమలు చేయండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "فائل ~/.soyeht/setup-token غائب ہے۔ براہ کرم انسٹالیشن دوبارہ چلائیں۔"
          }
        }
      }
    },
    "autoPair.error.pairTokenDecodeFailed": {
      "comment": "Auto-pair error — response from /pair-token didn't match the expected JSON shape.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
