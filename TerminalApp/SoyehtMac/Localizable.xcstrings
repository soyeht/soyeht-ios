    "installer.error.serverNeverBecameHealthy": {
      "comment": "Install error — `soyeht start` succeeded but /health never responded OK within the probe window.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بدأ الخادم لكنه لم يستجب في /health ضمن الحد. راجع ~/Library/Logs/theyos للحصول على التفاصيل."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "সার্ভার শুরু হয়েছে তবে সীমার মধ্যে /health-এ সাড়া দেয়নি। বিস্তারিত জানতে ~/Library/Logs/theyos দেখুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server wurde gestartet, antwortete jedoch nicht innerhalb der Zeit unter /health. Details siehe ~/Library/Logs/theyos."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The server started but did not respond at /health within the limit. See ~/Library/Logs/theyos for details."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor se inició pero no respondió en /health dentro del límite. Consulta ~/Library/Logs/theyos para más detalles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur a démarré mais n’a pas répondu sur /health dans la limite. Consultez ~/Library/Logs/theyos pour les détails."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्वर शुरू हो गया पर /health पर समय-सीमा में प्रतिक्रिया नहीं दी। विवरण के लिए ~/Library/Logs/theyos देखें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Server dimulai tetapi tidak merespons di /health dalam batas waktu. Lihat ~/Library/Logs/theyos untuk detail."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバーは起動しましたが、制限時間内に /health が応答しませんでした。詳細は ~/Library/Logs/theyos をご覧ください。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "सर्व्हर सुरू झाला पण मर्यादेत /health वर प्रतिसाद दिला नाही. तपशीलांसाठी ~/Library/Logs/theyos पहा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O servidor iniciou mas não respondeu em /health dentro do limite. Veja ~/Library/Logs/theyos para detalhes."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O servidor iniciou mas não respondeu em /health dentro do limite. Veja ~/Library/Logs/theyos para detalhes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сервер запустился, но не ответил на /health в пределах таймаута. Подробнее в ~/Library/Logs/theyos."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "సర్వర్ ప్రారంభమైంది కానీ పరిమితిలో /health వద్ద స్పందించలేదు. వివరాలకు ~/Library/Logs/theyos చూడండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سرور شروع ہو گیا لیکن حد کے اندر /health پر جواب نہیں دیا۔ تفصیلات کے لیے ~/Library/Logs/theyos دیکھیں۔"
          }
        }
      }
    },
