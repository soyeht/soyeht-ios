    "pairing.alert.revokeOne.message": {
      "comment": "Confirm alert body — consequence of revoking a single device.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لن يتمكن هذا iPhone من فتح لوحات على هذا Mac دون اقتران جديد."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নতুন পেয়ারিং ছাড়া এই iPhone এই Mac-এ pane খুলতে পারবে না।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses iPhone kann auf diesem Mac keine Bereiche mehr öffnen, bis eine neue Kopplung erfolgt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This iPhone will no longer be able to open panes on this Mac without a fresh pairing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ese iPhone ya no podrá abrir panes en este Mac sin un emparejamiento nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet iPhone ne pourra plus ouvrir de volet sur ce Mac sans un nouvel appairage."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह iPhone नए पेयरिंग के बिना इस Mac पर pane नहीं खोल सकेगा।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone ini tidak akan bisa membuka pane di Mac ini tanpa pemasangan baru."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone は再ペアリングするまで、この Mac でペインを開けなくなります。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "이 iPhone은 새로 페어링하기 전까지 이 Mac에서 패널을 열 수 없습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "如果不重新配对，这部 iPhone 将无法再在此 Mac 上打开窗格。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "नवीन जोडणीशिवाय हा iPhone या Mac वर panes उघडू शकणार नाही."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esse iPhone não poderá mais abrir painéis deste Mac sem um novo pareamento."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Este iPhone deixará de poder abrir painéis deste Mac sem um novo emparelhamento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот iPhone больше не сможет открывать panes на этом Mac без нового сопряжения."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "కొత్త జత లేకుండా ఈ iPhone ఈ Mac లో panes తెరవలేదు."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ iPhone نئے جوڑے کے بغیر اس Mac پر panes نہیں کھول سکے گا۔"
          }
        }
      }
    },
