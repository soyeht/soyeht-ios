    "installer.error.serverNeverBecameHealthy": {
      "comment": "Install error — `soyeht start` succeeded but /health never responded OK within the probe window.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بدأ الخادم لكنه لم يستجب في /health ضمن الحد. راجع ~/Library/Logs/Soyeht للحصول على التفاصيل."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সার্ভার শুরু হয়েছে তবে সীমার মধ্যে /health-এ সাড়া দেয়নি। বিস্তারিত জানতে ~/Library/Logs/Soyeht দেখুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server wurde gestartet, antwortete jedoch nicht innerhalb der Zeit unter /health. Details siehe ~/Library/Logs/Soyeht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The server started but did not respond at /health within the limit. See ~/Library/Logs/Soyeht for details."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La máquina se inició pero no respondió en /health dentro del límite. Consulta ~/Library/Logs/Soyeht para más detalles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur a démarré mais n’a pas répondu sur /health dans la limite. Consultez ~/Library/Logs/Soyeht pour les détails."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्वर शुरू हो गया पर /health पर समय-सीमा में प्रतिक्रिया नहीं दी। विवरण के लिए ~/Library/Logs/Soyeht देखें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Server dimulai tetapi tidak merespons di /health dalam batas waktu. Lihat ~/Library/Logs/Soyeht untuk detail."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバーは起動しましたが、制限時間内に /health が応答しませんでした。詳細は ~/Library/Logs/Soyeht をご覧ください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "서버가 시작되었지만 제한 시간 내에 /health에 응답하지 않았습니다. 자세한 내용은 ~/Library/Logs/Soyeht를 확인하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "服务器已启动，但 /health 未在限制时间内响应。详情请查看 ~/Library/Logs/Soyeht。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्व्हर सुरू झाला पण मर्यादेत /health वर प्रतिसाद दिला नाही. तपशीलांसाठी ~/Library/Logs/Soyeht पहा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A máquina iniciou mas não respondeu em /health dentro do limite. Veja ~/Library/Logs/Soyeht para detalhes."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A máquina iniciou mas não respondeu em /health dentro do limite. Veja ~/Library/Logs/Soyeht para detalhes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сервер запустился, но не ответил на /health в пределах таймаута. Подробнее в ~/Library/Logs/Soyeht."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "సర్వర్ ప్రారంభమైంది కానీ పరిమితిలో /health వద్ద స్పందించలేదు. వివరాలకు ~/Library/Logs/Soyeht చూడండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سرور شروع ہو گیا لیکن حد کے اندر /health پر جواب نہیں دیا۔ تفصیلات کے لیے ~/Library/Logs/Soyeht دیکھیں۔"
          }
        }
      }
    },
    "installer.error.subprocessFailed": {
      "comment": "Install error — a subprocess exited non-zero. %1$@ = label (e.g. 'brew install'), %2$lld = exit code, %3$@ = last ~30 lines of subprocess output.",
