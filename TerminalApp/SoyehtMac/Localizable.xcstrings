    "welcome.remoteConnect.header.description": {
      "comment": "Description under the remote-connect heading — explains the expected input format.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الصق رابط soyeht:// الذي أنشأته لوحة الإدارة. الصيغة: soyeht://connect?token=…&host=…"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Admin Panel এর দেওয়া soyeht:// লিঙ্ক পেস্ট করুন। ফর্ম্যাট: soyeht://connect?token=…&host=…"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie den soyeht://-Link aus dem Admin-Bereich ein. Format: soyeht://connect?token=…&host=…"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paste the soyeht:// link the Admin Panel gave you. Format: soyeht://connect?token=…&host=…"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pega el enlace soyeht:// que te dio el Panel de Administración. Formato: soyeht://connect?token=…&host=…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collez le lien soyeht:// fourni par le panneau d’administration. Format : soyeht://connect?token=…&host=…"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Admin Panel से मिला soyeht:// लिंक पेस्ट करें। प्रारूप: soyeht://connect?token=…&host=…"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tempel tautan soyeht:// dari Panel Admin. Format: soyeht://connect?token=…&host=…"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "管理パネルで生成された soyeht:// リンクを貼り付けてください。フォーマット: soyeht://connect?token=…&host=…"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "Admin Panel에서 받은 soyeht:// 링크를 붙여넣으세요. 형식: soyeht://connect?token=…&host=…"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "粘贴 Admin Panel 提供的 soyeht:// 链接。格式：soyeht://connect?token=…&host=…"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Admin Panel ने दिलेला soyeht:// लिंक पेस्ट करा. स्वरूप: soyeht://connect?token=…&host=…"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cole o link soyeht:// gerado pelo painel de administração. Formato: soyeht://connect?token=…&host=…"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Cole a ligação soyeht:// gerada pelo painel de administração. Formato: soyeht://connect?token=…&host=…"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вставьте ссылку soyeht://, которую сгенерировала панель администратора. Формат: soyeht://connect?token=…&host=…"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Admin Panel ఇచ్చిన soyeht:// లింక్ పేస్ట్ చేయండి. ఫార్మాట్: soyeht://connect?token=…&host=…"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایڈمن پینل کی طرف سے دیا گیا soyeht:// لنک چسپاں کریں۔ فارمیٹ: soyeht://connect?token=…&host=…"
          }
        }
      }
    },
