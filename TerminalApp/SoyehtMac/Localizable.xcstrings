    "welcome.localInstall.header.description": {
      "comment": "Copy under the local install heading — describes the automated install pipeline so the user doesn't expect a terminal prompt.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقوم التطبيق بتشغيل brew install Soyeht + soyeht start في الخلفية. لا حاجة لفتح الطرفية."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "অ্যাপ ব্যাকগ্রাউন্ডে brew install Soyeht + soyeht start চালায়। আপনাকে টার্মিনাল খুলতে হবে না।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die App führt `brew install Soyeht` + `soyeht start` im Hintergrund aus. Sie müssen das Terminal nicht öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app runs `brew install Soyeht` + `soyeht start` in the background. You don't need to open the terminal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La app ejecuta `brew install Soyeht` + `soyeht start` en segundo plano. No necesitas abrir la terminal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’app exécute brew install Soyeht + soyeht start en arrière-plan. Vous n’avez pas besoin d’ouvrir le terminal."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप बैकग्राउंड में brew install Soyeht + soyeht start चलाता है। टर्मिनल खोलने की ज़रूरत नहीं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikasi menjalankan brew install Soyeht + soyeht start di latar. Anda tidak perlu membuka terminal."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリはバックグラウンドで brew install Soyeht + soyeht start を実行します。ターミナルを開く必要はありません。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "앱이 백그라운드에서 brew install Soyeht + soyeht start를 실행합니다. 터미널을 열 필요가 없습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "应用会在后台运行 brew install Soyeht + soyeht start。你不需要打开终端。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "अ‍ॅप पार्श्वभूमीत brew install Soyeht + soyeht start चालवते. टर्मिनल उघडण्याची गरज नाही."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O app executa brew install Soyeht + soyeht start em segundo plano. Você não precisa abrir o terminal."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A aplicação executa brew install Soyeht + soyeht start em segundo plano. Não precisa de abrir o terminal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложение выполняет `brew install Soyeht` + `soyeht start` в фоне. Вам не нужно открывать терминал."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "యాప్ బ్యాక్‌గ్రౌండ్‌లో brew install Soyeht + soyeht start ను అమలు చేస్తుంది. మీరు టర్మినల్ తెరవాల్సిన అవసరం లేదు."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایپ پس منظر میں brew install Soyeht + soyeht start چلاتی ہے۔ ٹرمینل کھولنے کی ضرورت نہیں۔"
          }
        }
      }
    },
