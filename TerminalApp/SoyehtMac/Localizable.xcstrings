    "welcome.landing.subtitle": {
      "comment": "Subtitle shown under the Welcome heading. 'AI agents' refers to the claws (AI coding agents) that run inside isolated sandboxes.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
