    "pairing.alert.revokeAll.message": {
      "comment": "Confirm alert body — warning that all active sessions will be terminated.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستُنهى جميع الجلسات النشطة. سيحتاج كل iPhone إلى مسح رمز QR جديد لإعادة الاتصال."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "সমস্ত সক্রিয় সেশন বন্ধ হবে। পুনরায় সংযুক্ত হতে প্রতিটি iPhone-কে নতুন QR স্ক্যান করতে হবে।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle aktiven Sitzungen werden beendet. Jedes iPhone muss einen neuen QR scannen, um sich erneut zu verbinden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All active sessions will be terminated. Each iPhone will need to scan a new QR to reconnect."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se terminarán todas las sesiones activas. Cada iPhone deberá escanear un QR nuevo para reconectarse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toutes les sessions actives seront fermées. Chaque iPhone devra scanner un nouveau QR pour se reconnecter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सभी सक्रिय सत्र समाप्त होंगे। फिर से जुड़ने के लिए प्रत्येक iPhone को नया QR स्कैन करना होगा।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Semua sesi aktif akan dihentikan. Setiap iPhone perlu memindai QR baru untuk tersambung kembali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのアクティブなセッションが終了します。再接続するには、各 iPhone で新しい QR をスキャンする必要があります。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "सर्व सक्रिय सत्रे संपवली जातील. पुन्हा जोडण्यासाठी प्रत्येक iPhone ला नवीन QR स्कॅन करावा लागेल."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as sessões ativas serão encerradas. Cada iPhone precisará escanear um novo QR pra voltar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as sessões ativas serão encerradas. Cada iPhone precisará de ler um novo QR para voltar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все активные сессии будут завершены. Каждому iPhone потребуется отсканировать новый QR, чтобы переподключиться."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "అన్ని సక్రియ సెషన్లు ముగించబడతాయి. తిరిగి కనెక్ట్ కావడానికి ప్రతి iPhone కొత్త QR ను స్కాన్ చేయాల్సి ఉంటుంది."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "تمام فعال سیشن ختم ہو جائیں گے۔ ہر iPhone کو دوبارہ جڑنے کے لیے نیا QR اسکین کرنا ہوگا۔"
          }
        }
      }
    },
