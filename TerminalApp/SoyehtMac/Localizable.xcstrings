      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ينتهي خلال %1$lld:%2$@"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%1$lld:%2$@ এ মেয়াদোত্তীর্ণ"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Läuft ab in %1$lld:%2$@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Expires in %1$lld:%2$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Caduca en %1$lld:%2$@"
          }
        },
        "fr": {
