    "installer.error.subprocessTimedOut": {
      "comment": "Install error — a subprocess ran past the defensive timeout. %1$@ = label, %2$lld = seconds.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يستجب %1$@ خلال %2$lld ثانية. تم إنهاء العملية."
