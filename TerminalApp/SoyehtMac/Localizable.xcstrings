    "installer.error.subprocessTimedOut": {
      "comment": "Install error — a subprocess ran past the defensive timeout. %1$@ = label, %2$lld = seconds.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يستجب %1$@ خلال %2$lld ثانية. تم إنهاء العملية."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ %2$lld সেকেন্ডে সাড়া দেয়নি। প্রক্রিয়া বন্ধ।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ hat in %2$lld s nicht geantwortet. Prozess beendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ did not respond in %2$llds. Process terminated."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ no respondió en %2$lld s. Proceso terminado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ n’a pas répondu en %2$lld s. Processus terminé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ ने %2$lld सेकंड में प्रतिक्रिया नहीं दी। प्रक्रिया समाप्त।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ tidak merespons dalam %2$lld d. Proses dihentikan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ は %2$lld 秒以内に応答しませんでした。プロセスを終了しました。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "%1$@이(가) %2$lld초 안에 응답하지 않았습니다. 프로세스가 종료되었습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "%1$@ 在 %2$lld 秒内未响应。进程已终止。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ ने %2$lld सेकंदात प्रतिसाद दिला नाही. प्रक्रिया संपवली."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ não respondeu em %2$llds. Processo encerrado."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ não respondeu em %2$llds. Processo terminado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ не ответил за %2$lld с. Процесс завершён."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ %2$lld సెకన్లలో స్పందించలేదు. ప్రక్రియ ముగిసింది."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ نے %2$lld سیکنڈ میں جواب نہیں دیا۔ پروسیس ختم۔"
          }
        }
      }
    },
    "installer.error.tailscaleRequired": {
      "comment": "Install error — user selected the Tailscale mode but the Tailscale app isn't installed. Directs to tailscale.com/download.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتطلب هذا الوضع Tailscale. قم بتنزيله من tailscale.com/download وحاول مجددًا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই মোডের জন্য Tailscale প্রয়োজন। tailscale.com/download থেকে ডাউনলোড করুন এবং আবার চেষ্টা করুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Modus erfordert Tailscale. Laden Sie es von tailscale.com/download herunter und versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This mode requires Tailscale. Download it from tailscale.com/download and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este modo requiere Tailscale. Descárgalo desde tailscale.com/download e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce mode nécessite Tailscale. Téléchargez-le depuis tailscale.com/download et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस मोड के लिए Tailscale ज़रूरी है। tailscale.com/download से डाउनलोड करके पुनः प्रयास करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode ini membutuhkan Tailscale. Unduh dari tailscale.com/download dan coba lagi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このモードには Tailscale が必要です。tailscale.com/download からダウンロードして、もう一度お試しください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "이 모드에는 Tailscale이 필요합니다. tailscale.com/download에서 다운로드한 뒤 다시 시도하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "此模式需要 Tailscale。请从 tailscale.com/download 下载后重试。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "या मोडसाठी Tailscale आवश्यक आहे. tailscale.com/download वरून डाउनलोड करा आणि पुन्हा प्रयत्न करा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este modo precisa do Tailscale instalado. Baixe em tailscale.com/download e tente novamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Este modo requer o Tailscale. Descarregue em tailscale.com/download e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот режим требует Tailscale. Загрузите его с tailscale.com/download и повторите."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఈ మోడ్‌కు Tailscale అవసరం. tailscale.com/download నుండి డౌన్‌లోడ్ చేయండి మరియు మళ్ళీ ప్రయత్నించండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اس موڈ کے لیے Tailscale درکار ہے۔ tailscale.com/download سے ڈاؤن لوڈ کریں اور دوبارہ کوشش کریں۔"
          }
        }
      }
    },
    "installer.mode.localhost.description": {
      "comment": "Install-mode description — localhost. No Tailscale dep.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستمع الخادم على localhost فقط. بسيط وسريع وبدون تبعيات خارجية."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সার্ভার শুধুমাত্র localhost-এ শুনে। সহজ, দ্রুত, বাহ্যিক নির্ভরতা নেই।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server lauscht nur auf localhost. Einfach, schnell, ohne externe Abhängigkeiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The server listens only on localhost. Simple, fast, no external dependencies."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La máquina escucha solo en localhost. Simple, rápido, sin dependencias externas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur n’écoute que sur localhost. Simple, rapide, sans dépendances externes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्वर केवल localhost पर सुनता है। सरल, तेज़, बिना बाहरी निर्भरता के।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Server hanya mendengarkan di localhost. Sederhana, cepat, tanpa dependensi eksternal."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバーは localhost のみで待ち受けます。シンプルで高速、外部依存なし。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "서버는 localhost에서만 수신합니다. 단순하고 빠르며 외부 의존성이 없습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "服务器只监听 localhost。简单、快速，无外部依赖。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्व्हर फक्त localhost वर ऐकतो. साधे, जलद, बाह्य अवलंबित्व नाही."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A máquina escuta só em localhost. Simples, rápido, sem dependências externas."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A máquina escuta apenas em localhost. Simples, rápido, sem dependências externas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сервер слушает только на localhost. Просто, быстро, без внешних зависимостей."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "సర్వర్ కేవలం localhost పై వింటుంది. సులువు, వేగవంతం, బాహ్య ఆధారాలు లేవు."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سرور صرف localhost پر سنتا ہے۔ آسان، تیز، بغیر بیرونی انحصار کے۔"
          }
        }
      }
    },
