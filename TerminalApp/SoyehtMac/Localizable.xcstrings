    "installer.error.homebrewMissing": {
      "comment": "Install error — brew binary not found in PATH or standard locations. Directs user to brew.sh.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم العثور على Homebrew. ثبّته من brew.sh قبل المتابعة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew পাওয়া যায়নি। চালিয়ে যাওয়ার আগে brew.sh থেকে ইনস্টল করুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew nicht gefunden. Installieren Sie es von brew.sh, bevor Sie fortfahren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew not found. Please install it from brew.sh before continuing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se encontró Homebrew. Instálalo desde brew.sh antes de continuar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew introuvable. Installez-le depuis brew.sh avant de continuer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew नहीं मिला। जारी रखने से पहले brew.sh से इंस्टॉल करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew tidak ditemukan. Pasang dari brew.sh sebelum melanjutkan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
