            "value": "%1$lld:%2$@ में समाप्त"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kedaluwarsa dalam %1$lld:%2$@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効期限: あと %1$lld:%2$@"
          }
        },
        "mr": {
          "stringUnit": {
