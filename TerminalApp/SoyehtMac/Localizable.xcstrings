    "drawer.uninstallTheyOS.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يزيل ~100 GB من الأجهزة الافتراضية وصيغة brew، ويفصل هذا الخادم."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "~100 GB ভার্চুয়াল মেশিন এবং brew ফর্মুলা সরায়, এবং এই সার্ভারটি সংযোগ বিচ্ছিন্ন করে।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernt ~100 GB an VMs, die brew-Formel und trennt diesen Server."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Removes ~100 GB of VMs, the brew formula, and disconnects this server."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina ~100 GB de VM, la fórmula de brew y desconecta esta máquina."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime ~100 GB de VM, la formule brew, et déconnecte ce serveur."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "~100 GB VM, brew फ़ॉर्मूला हटाता है और इस सर्वर को डिस्कनेक्ट करता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menghapus ~100 GB VM, formula brew, dan memutuskan server ini."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "~100 GB の VM、brew フォーミュラを削除し、このサーバーを切断します。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "약 100 GB의 VM, brew formula를 제거하고 이 서버의 연결을 끊습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "移除约 100 GB 的 VM、brew formula，并断开此服务器。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "~100 GB VM, brew फॉर्म्युला काढून टाकते आणि हा सर्व्हर डिस्कनेक्ट करते."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove ~100 GB de VMs, a fórmula brew e desconecta esta máquina."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove ~100 GB de VMs, a fórmula brew e desliga esta máquina."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удаляет ~100 GB виртуальных машин, формулу brew и отключает этот сервер."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "~100 GB VMలను, brew ఫార్ములాను తొలగిస్తుంది మరియు ఈ సర్వర్‌ను డిస్‌కనెక్ట్ చేస్తుంది."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "~100 GB VMs، brew فارمولا ہٹاتا ہے اور اس سرور کو منقطع کر دیتا ہے۔"
          }
        }
      },
      "comment": "Subtitle under the uninstall button explaining the impact."
    },
