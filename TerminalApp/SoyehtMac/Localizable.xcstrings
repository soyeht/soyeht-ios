        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Respuesta inesperada del endpoint de emparejamiento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réponse inattendue du point de terminaison d’appairage."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पेयरिंग एंडपॉइंट से अप्रत्याशित प्रतिक्रिया।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Respons tak terduga dari endpoint pairing."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペアリング エンドポイントから予期しない応答がありました。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "페어링 엔드포인트에서 예상치 못한 응답을 받았습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "配对端点返回了意外响应。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "पेअरिंग एंडपॉइंटकडून अनपेक्षित प्रतिसाद."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Resposta inesperada do endpoint de pareamento."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Resposta inesperada do endpoint de emparelhamento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Неожиданный ответ от эндпоинта сопряжения."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "పెయిరింగ్ ఎండ్‌పాయింట్ నుండి ఊహించని స్పందన."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جوڑی بنانے کے اینڈپوائنٹ سے غیر متوقع جواب۔"
          }
        }
      }
