    "uninstaller.hint.sudoRm": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احتاجت بعض الملفات إلى صلاحيات root لحذفها. شغّل هذا في Terminal، ثم شغّل Uninstall مرة أخرى:\n\n%@"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Some files needed root to remove. Run this in Terminal, then re-run Uninstall:\n\n%@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einige Dateien benötigten Root-Rechte zum Entfernen. Führen Sie dies in Terminal aus und starten Sie danach Deinstallieren erneut:\n\n%@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some files needed root to remove. Run this in Terminal, then re-run Uninstall:\n\n%@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algunos archivos necesitaron permisos root para eliminarse. Ejecuta esto en Terminal y luego vuelve a ejecutar Desinstalar:\n\n%@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Certains fichiers nécessitaient les droits root pour être supprimés. Exécutez ceci dans Terminal, puis relancez Désinstaller :\n\n%@"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कुछ files remove करने के लिए root चाहिए था। इसे Terminal में run करें, फिर Uninstall दोबारा run करें:\n\n%@"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Beberapa file memerlukan root untuk dihapus. Jalankan ini di Terminal, lalu jalankan Uninstall lagi:\n\n%@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一部のファイルを削除するには root 権限が必要でした。Terminal でこれを実行してから、Uninstall をもう一度実行してください:\n\n%@"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "일부 파일을 제거하려면 root 권한이 필요했습니다. Terminal에서 다음을 실행한 다음 Uninstall을 다시 실행하세요:\n\n%@"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "有些文件需要 root 权限才能移除。请在 Terminal 中运行以下命令，然后重新运行 Uninstall：\n\n%@"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Some files needed root to remove. Run this in Terminal, then re-run Uninstall:\n\n%@"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Alguns arquivos exigiram root para serem removidos. Execute isto no Terminal e depois execute a desinstalação novamente:\n\n%@"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Alguns ficheiros exigiram root para serem removidos. Execute isto no Terminal e depois execute a desinstalação novamente:\n\n%@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для удаления некоторых файлов нужен root. Выполните это в Terminal, затем снова запустите Uninstall:\n\n%@"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Some files needed root to remove. Run this in Terminal, then re-run Uninstall:\n\n%@"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کچھ files remove کرنے کے لیے root چاہیے تھا۔ اسے Terminal میں run کریں، پھر Uninstall دوبارہ run کریں:\n\n%@"
          }
        }
      },
      "comment": "Hint surfaced when one or more uninstall steps hit EACCES on root-owned files. The %@ is one or more `sudo rm -rf <path>` lines."
    },
