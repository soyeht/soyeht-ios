    "servers.alert.disconnect.message": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى إزالة الرمز المحفوظ لـ %@. يمكنك الاتصال به مرة أخرى عبر رابط theyOS."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes the saved token for %@. You can connect it again with a theyOS link."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies entfernt das gespeicherte Token für %@. Sie können es mit einem theyOS-Link erneut verbinden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes the saved token for %@. You can connect it again with a theyOS link."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina el token guardado de %@. Puedes conectarlo de nuevo con un enlace theyOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime le token enregistré pour %@. Vous pourrez le reconnecter avec un lien theyOS."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह %@ का saved token remove करता है। आप इसे theyOS link से फिर connect कर सकते हैं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini menghapus token tersimpan untuk %@. Anda dapat menghubungkannya lagi dengan tautan theyOS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ の保存済みトークンを削除します。theyOS リンクで再接続できます。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "%@의 저장된 토큰을 제거합니다. theyOS 링크로 다시 연결할 수 있습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "这会移除 %@ 的已保存令牌。你可以使用 theyOS 链接再次连接。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes the saved token for %@. You can connect it again with a theyOS link."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso remove o token salvo para %@. Você pode conectar novamente com um link theyOS."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto remove o token guardado de %@. Pode ligá-lo novamente com uma ligação theyOS."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это удалит сохраненный токен для %@. Его можно подключить снова через ссылку theyOS."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes the saved token for %@. You can connect it again with a theyOS link."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ %@ کا saved token remove کرتا ہے۔ آپ اسے theyOS link سے دوبارہ connect کر سکتے ہیں۔"
          }
        }
      },
      "comment": "Confirm alert body when removing a connected theyOS server."
    },
