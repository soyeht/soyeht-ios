    "welcome.card.localInstall.subtitle": {
      "comment": "Subtitle under 'Install on my Mac' card describing the one-click local install.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نقرة واحدة. يقوم التطبيق بتشغيل التثبيت والاقتران تلقائيًا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "১ ক্লিক। অ্যাপ ইনস্টল চালায় এবং স্বয়ংক্রিয়ভাবে জোড়া তৈরি করে।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "1 Klick. Die App führt die Installation aus und koppelt automatisch."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1 click. The app runs the install and pairs automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "1 clic. La app ejecuta la instalación y se empareja automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "1 clic. L’app lance l’installation et s’appaire automatiquement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "1 क्लिक। ऐप इंस्टॉल चलाता है और अपने आप जोड़ी बनाता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "1 klik. Aplikasi menjalankan instalasi dan memasangkan secara otomatis."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1クリック。アプリがインストールを実行し、自動的にペアリングします。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "1 क्लिक. अ‍ॅप इंस्टॉलेशन चालवते आणि आपोआप जोडते."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "1 clique. O app roda a instalação e pareia automaticamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "1 clique. A aplicação executa a instalação e emparelha automaticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "1 клик. Приложение запускает установку и сопрягается автоматически."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "1 క్లిక్. యాప్ ఇన్‌స్టాల్‌ను అమలు చేస్తుంది మరియు స్వయంచాలకంగా జత అవుతుంది."
