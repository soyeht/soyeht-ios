{
  "sourceLanguage": "en",
  "strings": {
    "Install theyOS to manage your claws. Choose an option below:": {
      "comment": "A description of the benefits of installing theyOS.",
      "isCommentAutoGenerated": true
    },
    "No claws found": {
      "comment": "A message displayed when there are no claws in the store.",
      "isCommentAutoGenerated": true
    },
    "[%@]": {
      "comment": "A label displaying the language of a Claw. The argument is the language code of the Claw.",
      "isCommentAutoGenerated": true
    },
    "appEnv.error.noInstancesAvailable": {
      "comment": "Error thrown when the default container resolver can't find any provisioned instance on the server.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد حالة متاحة. قم بتهيئة واحدة على الخادم قبل بدء الجلسة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "কোনো ইনস্ট্যান্স উপলব্ধ নেই। সেশন শুরু করার আগে সার্ভারে একটি কনফিগার করুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Instanz verfügbar. Konfigurieren Sie eine auf dem Server, bevor Sie eine Sitzung starten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No instance available. Configure one on the server before starting a session."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay instancias disponibles. Configura una en el servidor antes de iniciar una sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune instance disponible. Configurez-en une sur le serveur avant de démarrer une session."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई इंस्टेंस उपलब्ध नहीं। सत्र शुरू करने से पहले सर्वर पर एक कॉन्फ़िगर करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada instance tersedia. Konfigurasikan satu di server sebelum memulai sesi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "利用可能なインスタンスがありません。セッションを開始する前にサーバーで設定してください。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "कोणतेही इन्स्टन्स उपलब्ध नाही. सत्र सुरू करण्यापूर्वी सर्व्हरवर एक कॉन्फिगर करा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma instância disponível. Configure uma no servidor antes de iniciar uma sessão."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma instância disponível. Configure uma no servidor antes de iniciar uma sessão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет доступного экземпляра. Настройте его на сервере перед запуском сессии."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ఎటువంటి ఇన్‌స్టాన్స్ అందుబాటులో లేదు. సెషన్ ప్రారంభించే ముందు సర్వర్‌లో ఒకదాన్ని కాన్ఫిగర్ చేయండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کوئی انسٹینس دستیاب نہیں۔ سیشن شروع کرنے سے پہلے سرور پر ایک ترتیب دیں۔"
          }
        }
      }
    },
