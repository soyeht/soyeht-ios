{
  "sourceLanguage": "en",
  "strings": {
    "Install Soyeht to manage your claws. Choose an option below:": {
      "comment": "A description of the benefits of installing Soyeht.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ثبّت Soyeht لإدارة claws الخاصة بك. اختر خيارًا أدناه:"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার claws পরিচালনা করতে Soyeht ইনস্টল করুন। নিচে একটি বিকল্প বেছে নিন:"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Installieren Sie Soyeht, um Ihre claws zu verwalten. Wählen Sie unten eine Option:"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Install Soyeht to manage your claws. Choose an option below:"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala Soyeht para administrar tus claws. Elige una opción abajo:"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Installez Soyeht pour gérer vos claws. Choisissez une option ci-dessous :"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने claws प्रबंधित करने के लिए Soyeht इंस्टॉल करें। नीचे एक विकल्प चुनें:"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasang Soyeht untuk mengelola claws Anda. Pilih opsi di bawah:"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "claws を管理するために Soyeht をインストールしてください。下のオプションを選択："
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "तुमच्या claws व्यवस्थापित करण्यासाठी Soyeht इन्स्टॉल करा. खाली एक पर्याय निवडा:"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale o Soyeht para gerenciar seus claws. Escolha uma opção abaixo:"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale o Soyeht para gerir os seus claws. Escolha uma opção abaixo:"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установите Soyeht, чтобы управлять вашими claws. Выберите вариант ниже:"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ clawsను నిర్వహించడానికి Soyehtను ఇన్‌స్టాల్ చేయండి. క్రింద ఒక ఎంపికను ఎంచుకోండి:"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنے claws کا انتظام کرنے کے لیے Soyeht انسٹال کریں۔ نیچے ایک آپشن منتخب کریں:"
          }
        }
      }
    },
    "No claws found": {
      "comment": "A message displayed when there are no claws in the store.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
