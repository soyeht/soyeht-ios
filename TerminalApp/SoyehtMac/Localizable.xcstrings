    "qrHandoff.header.subtitle": {
      "comment": "Subtitle explaining the two ways to redeem the QR link.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم كاميرا iPhone أو انسخ الرابط أدناه والصقه في تطبيق Soyeht لفتح نفس الجلسة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "iPhone ক্যামেরা ব্যবহার করুন বা নিচের লিঙ্কটি কপি করে Soyeht অ্যাপে পেস্ট করুন — একই সেশন খুলবে।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nutzen Sie die iPhone-Kamera oder kopieren Sie den Link unten und fügen Sie ihn in die Soyeht-App ein, um dieselbe Sitzung zu öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the iPhone camera or copy the link below and paste it into the Soyeht app to open this same session."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la cámara del iPhone o copia el enlace de abajo y pégalo en la app Soyeht para abrir esta misma sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez l’appareil photo de l’iPhone ou copiez le lien ci-dessous et collez-le dans l’app Soyeht pour ouvrir la même session."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone कैमरे का उपयोग करें या नीचे दिया गया लिंक कॉपी करके Soyeht ऐप में पेस्ट करें और वही सत्र खोलें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan kamera iPhone atau salin tautan di bawah dan tempel di aplikasi Soyeht untuk membuka sesi yang sama."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone のカメラを使うか、下のリンクをコピーして Soyeht アプリに貼り付けて、同じセッションを開いてください。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "iPhone कॅमेरा वापरा किंवा खालील लिंक कॉपी करून Soyeht अ‍ॅपमध्ये पेस्ट करा — तेच सत्र उघडेल."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a câmera do iPhone ou copie o link abaixo e cole no app Soyeht para abrir esta mesma sessão."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a câmara do iPhone ou copie o link abaixo e cole na aplicação Soyeht para abrir esta mesma sessão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте камеру iPhone или скопируйте ссылку ниже и вставьте её в приложение Soyeht, чтобы открыть ту же сессию."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "iPhone కెమెరాను ఉపయోగించండి లేదా క్రింది లింక్‌ను కాపీ చేసి Soyeht యాప్‌లో పేస్ట్ చేయండి — అదే సెషన్ తెరుచుకుంటుంది."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone کیمرہ استعمال کریں یا نیچے دی گئی لنک کاپی کر کے Soyeht ایپ میں چسپاں کریں تاکہ یہی سیشن کھلے۔"
          }
        }
      }
    },
