// Local override for Debug signing. Copy to `Local.xcconfig` (gitignored)
// and fill in your identity. The tracked `Base.xcconfig` does
// `#include?  "Local.xcconfig"` so anything you set here wins; if the file
// is absent (e.g. on CI) the defaults in `Base.xcconfig` (ad-hoc, no team)
// are used and the build still succeeds.
//
// Why bother: ad-hoc signing ("-") rotates the binary's signature hash on
// every rebuild, which makes macOS treat each Debug build as a new app and
// re-prompts TCC permissions (Documents, Files-and-Folders, Screen
// Recording, etc.) on every relaunch. A stable signing identity (Apple
// Development for a personal Apple ID, or Developer ID Application for a
// paid Developer Program account) makes TCC remember the grants across
// rebuilds.
//
// Find your identities with:
//   security find-identity -v -p codesigning

CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = Developer ID Application: Your Name (YOURTEAMID)
DEVELOPMENT_TEAM = YOURTEAMID
