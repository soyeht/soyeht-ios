    "settings.colorTheme.description": {
      "comment": "Description under color theme section.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يغير كل نسق ألوان ANSI الستة عشر وخلفية الطرفية ومقدمتها."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "প্রতিটি থিম টার্মিনালের 16টি ANSI রঙ, পটভূমি এবং সম্মুখভাগ পরিবর্তন করে।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jedes Thema ändert die 16 ANSI-Farben, den Hintergrund und den Vordergrund des Terminals."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each theme changes the 16 ANSI colors, background, and foreground of the terminal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada tema cambia los 16 colores ANSI, el fondo y el primer plano del terminal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque thème modifie les 16 couleurs ANSI, l’arrière-plan et l’avant-plan du terminal."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रत्येक थीम टर्मिनल के 16 ANSI रंग, पृष्ठभूमि और अग्रभूमि को बदलती है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Setiap tema mengubah 16 warna ANSI, latar belakang, dan latar depan terminal."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各テーマは、ターミナルの 16 色の ANSI カラー、背景、前景を変更します。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "प्रत्येक थीम टर्मिनलचे 16 ANSI रंग, पार्श्वभूमी आणि अग्रभूमी बदलते."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada tema altera as 16 cores ANSI, o plano de fundo e o primeiro plano do terminal."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada tema altera as 16 cores ANSI, o fundo e o primeiro plano do terminal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждая тема меняет 16 цветов ANSI, фон и передний план терминала."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ప్రతి థీమ్ టెర్మినల్‌లోని 16 ANSI రంగులు, నేపథ్యం మరియు ముందు రంగును మారుస్తుంది."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ہر تھیم ٹرمینل کے 16 ANSI رنگ، پس منظر اور پیش منظر کو تبدیل کرتی ہے۔"
          }
        }
      }
    },
