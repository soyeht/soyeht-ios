            "value": "// couleur du curseur"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "// कर्सर रंग"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "// warna kursor"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "// カーソルの色"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "// 커서 색상"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "// 光标颜色"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "// कर्सर रंग"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "// cor do cursor"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "// cor do cursor"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "// цвет курсора"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "// కర్సర్ రంగు"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "// کرسر کا رنگ"
          }
        }
      }
    },
    "settings.cursorStyle.section.color.description": {
      "comment": "Description under cursor color section.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر لون المؤشر. سيتم تطبيق اللون على النمط المختار أعلاه."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কার্সার রঙ বেছে নিন। রঙ উপরে বেছে নেওয়া শৈলীতে প্রয়োগ হবে।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle die Cursor-Farbe. Sie wird auf den oben gewählten Stil angewendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the cursor color. The color will be applied to the style chosen above."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el color del cursor. Se aplicará al estilo elegido arriba."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisis la couleur du curseur. Elle sera appliquée au style choisi ci-dessus."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कर्सर रंग चुनें। रंग ऊपर चुनी गई शैली पर लागू होगा।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih warna kursor. Warna akan diterapkan pada gaya yang dipilih di atas."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カーソルの色を選択してください。上で選択したスタイルに色が適用されます。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "커서 색상을 선택하세요. 위에서 선택한 스타일에 색상이 적용됩니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "选择光标颜色。该颜色会应用到上面选择的样式。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "कर्सर रंग निवडा. रंग वर निवडलेल्या शैलीवर लागू केला जाईल."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha a cor do cursor. Ela será aplicada ao estilo escolhido acima."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha a cor do cursor. Será aplicada ao estilo escolhido acima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите цвет курсора. Он будет применён к выбранному выше стилю."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "కర్సర్ రంగును ఎంచుకోండి. ఎంచుకున్న శైలికి రంగు వర్తించబడుతుంది."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کرسر کا رنگ منتخب کریں۔ رنگ اوپر منتخب کردہ انداز پر لاگو ہوگا۔"
          }
        }
      }
    },
    "settings.cursorStyle.section.default": {
