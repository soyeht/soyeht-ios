    "settings.shortcut.creator.label.footer": {
      "comment": "Footer under label field.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الاسم الظاهر على الزر. اتركه فارغاً للتلقائي."
