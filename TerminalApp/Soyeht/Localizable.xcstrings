    "settings.cursorStyle.section.default.description": {
      "comment": "Description under the cursor style section.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يدعم SwiftTerm ٦ أنماط للمؤشر. اختر النمط الافتراضي."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "SwiftTerm 6টি কার্সার শৈলী সমর্থন করে। ডিফল্ট নির্বাচন করুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftTerm unterstützt 6 Cursor-Stile. Wähle den Standard."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftTerm supports 6 cursor styles. Choose the default."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftTerm admite 6 estilos de cursor. Elige el predeterminado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftTerm prend en charge 6 styles de curseur. Choisis celui par défaut."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftTerm 6 कर्सर शैलियों का समर्थन करता है। डिफ़ॉल्ट चुनें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftTerm mendukung 6 gaya kursor. Pilih yang bawaan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftTerm は 6 種類のカーソルスタイルに対応しています。デフォルトを選択してください。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "SwiftTerm 6 कर्सर शैलींना समर्थन देते. डीफॉल्ट निवडा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O SwiftTerm suporta 6 estilos de cursor. Escolha o padrão."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O SwiftTerm suporta 6 estilos de cursor. Escolha o predefinido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftTerm поддерживает 6 стилей курсора. Выберите стиль по умолчанию."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "SwiftTerm 6 కర్సర్ శైలులకు మద్దతు ఇస్తుంది. డిఫాల్ట్‌ను ఎంచుకోండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftTerm 6 کرسر انداز کی حمایت کرتا ہے۔ ڈیفالٹ منتخب کریں۔"
          }
        }
      }
    },
