    "qrFallback.title": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ثبّت Soyeht على Mac"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার Mac-এ Soyeht ইনস্টল করুন"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Soyeht auf Ihrem Mac installieren"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Install Soyeht on your Mac"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala Soyeht en tu Mac"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Installez Soyeht sur votre Mac"
          }
