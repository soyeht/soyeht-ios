    "recovery.body": {
      "comment": "Recovery message body. Calm, non-alarming. Explains multi-device key recovery.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا فقدت يومًا جهاز iPhone، يمكن لـ Mac آخر استرداد منزلك. مفاتيحك تظل آمنة — لا تعتمد على أي جهاز بمفرده."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you ever lose your iPhone, another Mac can recover your home. Your keys stay safe — they don't depend on any single device."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगर आप कभी iPhone खो दें, तो दूसरा Mac आपका घर वापस पा सकता है। आपकी चाबियां सुरक्षित रहती हैं — वे किसी एक डिवाइस पर निर्भर नहीं हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いつかiPhoneを紛失しても、別のMacがあなたのホームを復元できます。鍵は安全に保管され、どのデバイスにも依存しません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se um dia você perder o iPhone, outro Mac pode recuperar sua casa. Suas chaves ficam seguras — não dependem de nenhum dispositivo sozinho."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Se algum dia perder o iPhone, outro Mac pode recuperar a sua casa. As suas chaves continuam seguras: não dependem de um único dispositivo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si alguna vez pierdes tu iPhone, otro Mac puede recuperar tu casa. Tus claves siguen seguras: no dependen de un solo dispositivo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie Ihr iPhone verlieren, kann ein anderer Mac Ihr Zuhause wiederherstellen. Ihre Schlüssel bleiben sicher: Sie hängen nicht von einem einzelnen Gerät ab."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous perdez un jour votre iPhone, un autre Mac pourra récupérer votre maison. Vos clés restent en sécurité : elles ne dépendent pas d’un seul appareil."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "If you ever lose your iPhone, another Mac can recover your home. Your keys stay safe — they don't depend on any single device."
          }
        },
        "id": {
          "stringUnit": {
            "state": "needs_review",
            "value": "If you ever lose your iPhone, another Mac can recover your home. Your keys stay safe — they don't depend on any single device."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "If you ever lose your iPhone, another Mac can recover your home. Your keys stay safe — they don't depend on any single device."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "If you ever lose your iPhone, another Mac can recover your home. Your keys stay safe — they don't depend on any single device."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "If you ever lose your iPhone, another Mac can recover your home. Your keys stay safe — they don't depend on any single device."
          }
        },
        "bn": {
