    "carousel.card5.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أعد الإعداد على Mac وادخل من أي مكان عبر iPhone. منزل واحد وطريقتان للدخول."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Set up on Mac, access from anywhere on iPhone. One home, two ways in."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf dem Mac einrichten, von überall auf dem iPhone zugreifen. Ein Zuhause, zwei Wege hinein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set up on Mac, access from anywhere on iPhone. One home, two ways in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configura en Mac y accede desde cualquier lugar en iPhone. Una casa, dos formas de entrar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurez sur Mac, accédez depuis n’importe où sur iPhone. Une maison, deux façons d’entrer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac पर set up करें, iPhone से कहीं से भी access करें। One home, two ways in."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Siapkan di Mac, akses dari mana saja di iPhone. Satu rumah, dua cara masuk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac で設定し、iPhone でどこからでもアクセスできます。1 つの家に 2 つの入り口。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "Mac에서 설정하고 iPhone으로 어디서든 접근하세요. 하나의 홈, 두 가지 입구입니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "在 Mac 上设置，在 iPhone 上随处访问。一个家，两种入口。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Set up on Mac, access from anywhere on iPhone. One home, two ways in."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure no Mac, acesse de qualquer lugar pelo iPhone. Uma casa, dois jeitos de entrar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure no Mac e aceda a partir de qualquer lugar pelo iPhone. Uma casa, duas formas de entrar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте на Mac и заходите откуда угодно с iPhone. Один дом, два способа входа."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Set up on Mac, access from anywhere on iPhone. One home, two ways in."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac پر set up کریں، iPhone سے کہیں سے بھی access کریں۔ One home, two ways in."
