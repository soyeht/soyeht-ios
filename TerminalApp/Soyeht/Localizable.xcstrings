    "carousel.card4.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحدث إلى وكلائك، بطريقة أكثر طبيعية من الكتابة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার এজেন্টদের সঙ্গে কথা বলুন, টাইপ করার চেয়ে বেশি স্বাভাবিক।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprechen Sie mit Ihren Agenten, natürlicher als Tippen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk to your agents, more natural than typing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Habla con tus agentes, más natural que escribir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parlez à vos agents, plus naturellement qu’en tapant."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने agents से बात करें, typing से ज़्यादा natural."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Bicaralah dengan agen Anda, lebih alami daripada mengetik."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントに話しかけるほうが、入力より自然です。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "에이전트에게 말하세요. 타이핑보다 더 자연스럽습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "和你的智能体说话，比打字更自然。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "तुमच्या agents शी बोला, typing पेक्षा अधिक natural."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fale com seus agentes, mais natural do que digitar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Fale com os seus agentes, mais natural do que escrever."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Говорите со своими агентами, это естественнее, чем печатать."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ agents తో మాట్లాడండి, typing కంటే natural గా ఉంటుంది."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنے agents سے بات کریں، typing سے زیادہ natural۔"
          }
        }
      },
      "comment": "Carousel card 4 subtitle: voice is natural and precise."
    },
