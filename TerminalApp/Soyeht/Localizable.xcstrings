    "parkingLot.subtitle": {
      "comment": "Parking lot subtitle explaining how to install later.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عندما يكون Mac بالقرب منك، افتح الرابط أدناه وثبّت التطبيق في أقل من دقيقة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When you have a Mac nearby, visit the link below and install in under a minute."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आपके पास Mac हो, तो नीचे दिए लिंक पर जाएं और एक मिनट में इंस्टॉल करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macが手元にあるとき、下のリンクにアクセスして1分以内にインストールできます。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "근처에 Mac이 있을 때 아래 링크로 이동하면 1분 안에 설치할 수 있습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "当 Mac 在你身边时，访问下面的链接，不到一分钟即可安装。"}},
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando você tiver um Mac por perto, acesse o link abaixo e instale em menos de um minuto."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando tiver um Mac por perto, abra a ligação abaixo e instale em menos de um minuto."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando tengas un Mac cerca, visita el enlace de abajo e instálalo en menos de un minuto."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn ein Mac in der Nähe ist, öffnen Sie den Link unten und installieren Sie es in weniger als einer Minute."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quand vous avez un Mac à proximité, ouvrez le lien ci-dessous et installez en moins d’une minute."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда рядом будет Mac, откройте ссылку ниже и установите приложение меньше чем за минуту."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Saat ada Mac di dekat Anda, buka tautan di bawah dan instal dalam waktu kurang dari satu menit."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جب آپ کے پاس Mac قریب ہو، نیچے دیے گئے link پر جائیں اور ایک minute سے کم وقت میں install کریں۔"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "When you have a Mac nearby, visit the link below and install in under a minute."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "When you have a Mac nearby, visit the link below and install in under a minute."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "When you have a Mac nearby, visit the link below and install in under a minute."
          }
        }
      }
    },
