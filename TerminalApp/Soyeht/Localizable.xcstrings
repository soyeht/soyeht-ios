    "cellular.sheet.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حجم مثبت Soyeht بضعة ميغابايت. نوصي بانتظار Wi-Fi حتى لا تستهلك باقة البيانات."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "The Soyeht installer is a few megabytes. We recommend waiting for Wi-Fi so you don't use your data allowance."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Soyeht-Installer ist einige Megabyte groß. Wir empfehlen, auf WLAN zu warten, damit Ihr Datenvolumen nicht verbraucht wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Soyeht installer is a few megabytes. We recommend waiting for Wi-Fi so you don't use your data allowance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El instalador de Soyeht pesa unos pocos megabytes. Recomendamos esperar a tener Wi-Fi para no consumir tus datos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le programme d’installation de Soyeht fait quelques mégaoctets. Nous recommandons d’attendre le Wi-Fi pour éviter de consommer votre forfait."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Soyeht installer कुछ megabytes का है। Data allowance बचाने के लिए Wi-Fi का इंतज़ार करना बेहतर है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Installer Soyeht berukuran beberapa megabyte. Sebaiknya tunggu Wi‑Fi agar kuota data Anda tidak terpakai."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Soyeht インストーラは数 MB あります。データ容量を使わないよう、Wi-Fi を待つことをおすすめします。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "Soyeht 설치 프로그램은 몇 MB입니다. 데이터 한도를 사용하지 않도록 Wi-Fi를 기다리는 것을 권장합니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "Soyeht 安装程序有几 MB。建议等待 Wi‑Fi，以免消耗你的流量。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "The Soyeht installer is a few megabytes. We recommend waiting for Wi-Fi so you don't use your data allowance."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O instalador do Soyeht tem alguns megabytes. Recomendamos esperar uma conexão Wi-Fi para não usar sua franquia."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O instalador do Soyeht tem alguns megabytes. Recomendamos aguardar pelo Wi-Fi para não consumir o seu plano de dados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установщик Soyeht занимает несколько мегабайт. Лучше дождаться Wi‑Fi, чтобы не расходовать мобильный трафик."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "The Soyeht installer is a few megabytes. We recommend waiting for Wi-Fi so you don't use your data allowance."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Soyeht installer چند megabytes کا ہے۔ Data allowance بچانے کے لیے Wi-Fi کا انتظار کرنا بہتر ہے۔"
          }
        }
      },
      "comment": "Cellular confirmation sheet body. Friendly tone about data usage."
    },
