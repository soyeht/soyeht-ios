    "attachment.alert.locationDenied.message": {
      "comment": "Alert body asking the user to enable location access.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable location access in Settings to share your position."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative o acesso à localização em Ajustes para compartilhar sua posição."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative o acesso à localização nas Definições para partilhar a sua posição."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa el acceso a la ubicación en Ajustes para compartir tu posición."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie den Standortzugriff in den Einstellungen, um Ihre Position zu teilen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez l’accès à la position dans Réglages pour partager votre position."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешите доступ к геопозиции в Настройках, чтобы поделиться своим местоположением."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktifkan akses lokasi di Pengaturan untuk membagikan posisi Anda."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فعّل الوصول إلى الموقع من الإعدادات لمشاركة موقعك."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنی position share کرنے کے لیے Settings میں location access enable کریں۔"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報を共有するには、設定で位置情報へのアクセスを有効にしてください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "위치를 공유하려면 설정에서 위치 접근을 활성화하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "请在“设置”中启用位置访问，以分享你的位置。"}},
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपनी position share करने के लिए Settings में location access enable करें।"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable location access in Settings to share your position."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable location access in Settings to share your position."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable location access in Settings to share your position."
          }
        }
      }
    },
