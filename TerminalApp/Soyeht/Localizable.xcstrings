      "comment": "QR token expired or was already consumed.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انتهى رمز QR أو تم استخدامه. أنشئ واحدًا جديدًا على Mac."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "QR-এর মেয়াদ শেষ বা ইতিমধ্যে ব্যবহৃত। Mac-এ নতুন তৈরি করুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der QR ist abgelaufen oder wurde bereits verwendet. Erzeugen Sie einen neuen auf dem Mac."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The QR expired or was already used. Generate a new one on the Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El QR expiró o ya fue usado. Genera uno nuevo en el Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le QR a expiré ou a déjà été utilisé. Générez-en un nouveau sur le Mac."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "QR समाप्त या पहले से उपयोग। Mac पर नया बनाएँ।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "QR kedaluwarsa atau sudah dipakai. Buat yang baru di Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "QR の有効期限が切れたか、すでに使用されています。Mac で新しいものを生成してください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "QR이 만료되었거나 이미 사용되었습니다. Mac에서 새 QR을 생성하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "QR 已过期或已被使用。请在 Mac 上生成新的 QR。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "QR कालबाह्य किंवा आधीच वापरलेला. Mac वर नवीन तयार करा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O QR expirou ou já foi usado. Gere um novo no Mac."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O QR expirou ou já foi usado. Gere um novo no Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "QR истёк или уже использован. Сгенерируйте новый на Mac."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "QR గడువు ముగిసింది లేదా ఇప్పటికే ఉపయోగించబడింది. Mac లో కొత్తది సృష్టించండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "QR کی میعاد ختم ہو گئی یا پہلے استعمال ہو چکا۔ Mac پر نیا بنائیں۔"
          }
        }
      }
    },
