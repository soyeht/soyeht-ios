    "clawSetup.privacyNotice": {
      "comment": "Privacy disclaimer under the assignment selector.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد التعيين، لن يكون لديك وصول إلى بيانات هذا المستخدم"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "অ্যাসাইন করার পরে, আপনি এই ব্যবহারকারীর ডেটা অ্যাক্সেস পাবেন না"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "nach zuweisung haben sie keinen zugriff auf die daten dieses benutzers"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "once assigned, you will not have access to this user's data"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "una vez asignado, no tendrás acceso a los datos de este usuario"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "une fois attribué, vous n’aurez plus accès aux données de cet utilisateur"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "असाइन करने के बाद, आपके पास इस यूज़र के डेटा का एक्सेस नहीं होगा"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "setelah ditugaskan, Anda tidak akan memiliki akses ke data pengguna ini"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "割り当て後は、このユーザーのデータにアクセスできません"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "नियुक्तीनंतर, तुम्हाला या वापरकर्त्याच्या डेटाचा प्रवेश नसेल"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "após atribuição, você não terá acesso aos dados deste usuário"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "depois de atribuído, não terá acesso aos dados deste utilizador"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "после назначения у вас не будет доступа к данным этого пользователя"
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "అసైన్ చేసిన తర్వాత, ఈ వినియోగదారు డేటాకు మీకు యాక్సెస్ ఉండదు"
          }
        },
        "ur": {
          "stringUnit": {
