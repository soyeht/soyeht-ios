    "moradorExplainer.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wohnen bedeutet, dass Ihr Mac die physische Basis Ihres digitalen Zuhauses ist. Er speichert die Daten und führt die Agents aus, so wie ein echtes Haus ein Fundament hat. Sie können von jedem Gerät aus zugreifen, aber der Mac ist das Zentrum."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vivir significa que tu Mac es la base física de tu casa digital. Guarda los datos y ejecuta los agentes, como una casa real tiene cimientos. Puedes acceder desde cualquier dispositivo, pero el Mac es el centro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Habiter signifie que votre Mac est la base physique de votre maison numérique. Il stocke les données et exécute les agents, comme une vraie maison repose sur des fondations. Vous pouvez y accéder depuis n’importe quel appareil, mais le Mac est le centre."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "id": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Morar significa que seu Mac é a base física da sua casa digital. Ele armazena os dados e roda os agentes — como uma casa de verdade tem alicerces. Você acessa de qualquer dispositivo, mas o Mac é o centro."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Morar significa que seu Mac é a base física da sua casa digital. Ele armazena os dados e roda os agentes — como uma casa de verdade tem alicerces. Você acessa de qualquer dispositivo, mas o Mac é o centro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        }
      },
      "comment": "Prose explaining what 'morar' means in Soyeht. Keep warm and non-technical."
    },
