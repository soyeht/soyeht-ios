    "settings.shortcutBar.create.footer": {
      "comment": "Footer tip under the create-shortcut button.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تطبق الإعدادات مجموعة مفاتيح محسّنة لكل سير عمل."
