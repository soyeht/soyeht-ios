    "settings.voice.description": {
      "comment": "Description under voice-to-text section.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أملِ الأوامر على أدوات الذكاء الاصطناعي بدلاً من الكتابة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "টাইপ করার বদলে AI কোডিং টুলগুলিতে প্রম্পট বলুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diktiere Prompts an KI-Coding-Tools, statt sie zu tippen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dictate prompts to AI coding tools instead of typing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dicta prompts a herramientas de IA en lugar de escribir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dicte des prompts aux outils d’IA plutôt que de taper."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टाइप करने के बजाय AI कोडिंग टूल्स को प्रॉम्प्ट बोलें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dikte prompt ke alat AI alih-alih mengetik."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AI コーディングツールにタイプせず音声でプロンプトを口述します。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "टाइप करण्याऐवजी AI कोडिंग साधनांना प्रॉम्प्ट सांगा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dite prompts pras ferramentas de IA em vez de digitar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Dite prompts às ferramentas de IA em vez de escrever."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Диктуйте подсказки AI-инструментам вместо ввода."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "టైప్ చేయడానికి బదులుగా AI కోడింగ్ టూల్స్‌కు ప్రాంప్ట్‌లను డిక్టేట్ చేయండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ٹائپ کرنے کے بجائے AI ٹولز کو پرامپٹ بولیں۔"
          }
        }
      }
    },
    "settings.voice.info": {
      "comment": "Info footer about iOS 26 + on-device processing.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتطلب iOS 26. تتم معالجة الكلام بالكامل على الجهاز."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "iOS 26 প্রয়োজন। স্পিচ সম্পূর্ণ ডিভাইসে প্রক্রিয়া হয়।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfordert iOS 26. Die Sprache wird vollständig auf dem Gerät verarbeitet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Requires iOS 26. Speech is processed entirely on-device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Requiere iOS 26. La voz se procesa íntegramente en el dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nécessite iOS 26. La parole est traitée entièrement sur l’appareil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 26 आवश्यक। वाणी पूरी तरह डिवाइस पर संसाधित होती है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Memerlukan iOS 26. Ucapan diproses sepenuhnya di perangkat."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 26 が必要です。音声はすべて端末上で処理されます。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "iOS 26 आवश्यक. भाषण पूर्णपणे डिव्हाइसवरच प्रक्रिया होते."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Requer iOS 26. A fala é processada inteiramente no dispositivo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Requer iOS 26. A fala é processada inteiramente no dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Требуется iOS 26. Речь обрабатывается полностью на устройстве."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "iOS 26 అవసరం. ప్రసంగం పూర్తిగా పరికరంలోనే ప్రాసెస్ చేయబడుతుంది."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 26 درکار ہے۔ تقریر مکمل طور پر ڈیوائس پر پراسیس ہوتی ہے۔"
          }
        }
      }
    },
