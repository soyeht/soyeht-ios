    "voice.permission.microphoneDenied": {
      "comment": "Shown when microphone access is denied — directs user to Settings.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم رفض الوصول إلى الميكروفون. افتح الإعدادات للتفعيل."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "মাইক্রোফোন অ্যাক্সেস প্রত্যাখ্যাত। সক্ষম করতে সেটিংস খুলুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofonzugriff verweigert. Öffne Einstellungen, um es zu aktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Microphone access denied. Open Settings to enable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acceso al micrófono denegado. Abre Ajustes para habilitarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accès au micro refusé. Ouvrez Réglages pour l’activer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "माइक्रोफोन एक्सेस अस्वीकृत। सक्षम करने के लिए सेटिंग्स खोलें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses mikrofon ditolak. Buka Pengaturan untuk mengaktifkan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクへのアクセスが拒否されました。設定を開いて有効にしてください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "마이크 접근이 거부되었습니다. 설정을 열어 활성화하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "麦克风访问已被拒绝。请打开“设置”启用。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "मायक्रोफोन प्रवेश नाकारला. सक्षम करण्यासाठी सेटिंग्ज उघडा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acesso ao microfone negado. Abra os Ajustes para habilitar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Acesso ao microfone negado. Abra as Definições para ativar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к микрофону запрещён. Откройте Настройки, чтобы включить."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మైక్రోఫోన్ యాక్సెస్ తిరస్కరించబడింది. ప్రారంభించడానికి సెట్టింగ్‌లు తెరవండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مائیکروفون تک رسائی مسترد۔ فعال کرنے کے لیے ترتیبات کھولیں۔"
          }
        }
      }
    },
    "settings.householdApplePush.applyFailed": {
      "comment": "Banner shown after the Apple Push Service toggle is flipped but the underlying registration/suspension call failed; the toggle is reverted to its previous state.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t update Apple Push Service. The setting was reverted; try again."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível atualizar o Apple Push Service. A configuração foi revertida; tente novamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível atualizar o Apple Push Service. A definição foi revertida; tente novamente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo actualizar Apple Push Service. Se revirtió el ajuste; inténtalo de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Push Service konnte nicht aktualisiert werden. Die Einstellung wurde zurückgesetzt; versuchen Sie es erneut."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de mettre à jour Apple Push Service. Le réglage a été rétabli ; réessayez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось обновить Apple Push Service. Настройка была возвращена; попробуйте снова."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak dapat memperbarui Apple Push Service. Pengaturan dikembalikan; coba lagi."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر تحديث Apple Push Service. تمت استعادة الإعداد السابق؛ حاول مجددًا."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Push Service update نہیں ہو سکا۔ setting واپس کر دی گئی؛ دوبارہ کوشش کریں۔"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Push Service を更新できませんでした。設定は元に戻されました。もう一度お試しください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "Apple Push Service를 업데이트할 수 없습니다. 설정이 되돌려졌습니다. 다시 시도하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "无法更新 Apple Push Service。设置已恢复，请重试。"}},
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Push Service update नहीं हो सका। setting वापस कर दी गई; फिर कोशिश करें।"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t update Apple Push Service. The setting was reverted; try again."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t update Apple Push Service. The setting was reverted; try again."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t update Apple Push Service. The setting was reverted; try again."
          }
        }
      }
    },
