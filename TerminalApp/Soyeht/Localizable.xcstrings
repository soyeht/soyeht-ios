      }
    },
    "parkingLot.subtitle": {
      "comment": "Parking lot subtitle explaining how to install later.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عندما يكون Mac بالقرب منك، افتح الرابط أدناه وثبّت التطبيق في أقل من دقيقة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When you have a Mac nearby, visit the link below and install in under a minute."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आपके पास Mac हो, तो नीचे दिए लिंक पर जाएं और एक मिनट में इंस्टॉल करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macが手元にあるとき、下のリンクにアクセスして1分以内にインストールできます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando você tiver um Mac por perto, acesse o link abaixo e instale em menos de um minuto."
          }
        }
      }
    },
