    "proximity.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنساعدك على تشغيل Soyeht على Mac باستخدام رابط تنزيل."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "একটি ডাউনলোড লিংক দিয়ে আপনার Mac-এ Soyeht চালু করতে আমরা সাহায্য করব।"
          }
        },
        "de": {
          "stringUnit": {
