    "settings.shortcutBar.section.active.description": {
      "comment": "Description — how to use the shortcut bar.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسحب لإعادة الترتيب. اسحب أفقياً للإزالة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "পুনঃক্রম করতে টানুন। সরাতে সোয়াইপ করুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zum Neuordnen ziehen. Zum Entfernen wischen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag to reorder. Swipe to remove."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra para reordenar. Desliza para eliminar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fais glisser pour réorganiser. Balaie pour supprimer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्रम बदलने के लिए खींचें। हटाने के लिए स्वाइप करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Seret untuk mengurutkan. Geser untuk menghapus."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ドラッグで並べ替え。スワイプで削除。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "पुनःक्रमित करण्यासाठी ड्रॅग करा. काढण्यासाठी स्वाइप करा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Arraste para reordenar. Deslize para remover."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Arraste para reordenar. Deslize para remover."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите, чтобы изменить порядок. Проведите, чтобы удалить."
