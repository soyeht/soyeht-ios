    "instancelist.alert.delete.message": {
      "comment": "Confirm body — permanent delete. %@ = instance name.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيحذف هذا %@ نهائيًا. لا يمكن التراجع."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এটি %@ স্থায়ীভাবে মুছে ফেলবে। পূর্বাবস্থায় ফেরানো যাবে না।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "dies löscht %@ dauerhaft. kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "this will permanently delete %@. this cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "esto eliminará %@ permanentemente. no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ceci supprimera %@ de façon permanente. impossible à annuler."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह %@ को स्थायी रूप से हटा देगा। पूर्ववत नहीं हो सकता।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "ini akan menghapus %@ secara permanen. tidak dapat dibatalkan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ が完全に削除されます。この操作は取り消せません。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "%@이(가) 영구적으로 삭제됩니다. 이 작업은 되돌릴 수 없습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "这将永久删除 %@。此操作无法撤销。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "यामुळे %@ कायमचे हटवले जाईल. पूर्ववत करता येणार नाही."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "isto vai apagar %@ permanentemente. não pode ser desfeito."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "isto vai apagar %@ permanentemente. não pode ser anulado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "это окончательно удалит %@. отменить нельзя."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఇది %@ ను శాశ్వతంగా తొలగిస్తుంది. తిరిగి పొందలేరు."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اس سے %@ مستقل طور پر حذف ہو جائے گا۔ کالعدم نہیں ہو سکتا۔"
          }
        }
      }
    },
