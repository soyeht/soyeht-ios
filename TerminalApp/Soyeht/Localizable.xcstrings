          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ボタンに表示される名前。自動にする場合は空のままにします。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "버튼에 표시될 이름입니다. 자동으로 하려면 비워 두세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "显示在按钮上的名称。留空则自动生成。"}},
        "mr": {
          "stringUnit": {
