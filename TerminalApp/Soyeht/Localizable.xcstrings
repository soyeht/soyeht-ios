    "lowBattery.sheet.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "البطارية أقل من 20%. تستغرق العملية بضع دقائق، لذلك من الأفضل شحنها قليلًا قبل البدء."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Your battery is below 20%. The process takes a few minutes, so it is better to charge a little before starting."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Akku liegt unter 20 %. Der Vorgang dauert einige Minuten, daher sollten Sie vor dem Start etwas aufladen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your battery is below 20%. The process takes a few minutes, so it is better to charge a little before starting."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu batería está por debajo del 20 %. El proceso tarda unos minutos, así que es mejor cargar un poco antes de empezar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre batterie est sous les 20 %. Le processus prend quelques minutes ; il vaut mieux charger un peu avant de commencer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी battery 20% से कम है। Process में कुछ minutes लगते हैं, इसलिए शुरू करने से पहले थोड़ा charge करना बेहतर है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Baterai Anda di bawah 20%. Proses ini memerlukan beberapa menit, jadi sebaiknya isi daya sebentar sebelum mulai."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バッテリー残量が 20% 未満です。処理には数分かかるため、開始前に少し充電することをおすすめします。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "배터리가 20% 미만입니다. 이 과정은 몇 분 걸리므로 시작 전에 조금 충전하는 것이 좋습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "你的电量低于 20%。这个过程需要几分钟，最好先充一会儿电再开始。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Your battery is below 20%. The process takes a few minutes, so it is better to charge a little before starting."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua bateria está abaixo de 20%. O processo leva alguns minutos — é melhor carregar um pouco antes de começar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A sua bateria está abaixo de 20%. O processo leva alguns minutos — é melhor carregar um pouco antes de começar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Заряд батареи ниже 20%. Процесс займет несколько минут, поэтому лучше немного зарядить устройство перед началом."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Your battery is below 20%. The process takes a few minutes, so it is better to charge a little before starting."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کی battery 20% سے کم ہے۔ Process میں چند minutes لگتے ہیں، اس لیے شروع کرنے سے پہلے تھوڑا charge کرنا بہتر ہے۔"
          }
        }
      },
      "comment": "Low battery warning body. Warm tone, non-alarming."
    },
