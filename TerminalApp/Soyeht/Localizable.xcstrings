    "carousel.card2.title": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وكلاؤك يعملون معًا"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার এজেন্টরা একসঙ্গে কাজ করে"
