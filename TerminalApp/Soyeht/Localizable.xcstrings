    "household.pairDevice.confirm.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يريد هذا الرابط تسجيلك كمالك مؤسس لمنزل جديد. تأكد أن البصمة أدناه تطابق البصمة المعروضة على جهاز Mac الذي عرض رمز QR."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "This link wants to enroll you as the founding owner of a new household. Verify the fingerprint below matches the one shown on the Mac that displayed the QR."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Link möchte Sie als gründenden Eigentümer eines neuen Zuhauses registrieren. Prüfen Sie, ob der Fingerabdruck unten mit dem auf dem Mac angezeigten übereinstimmt, der den QR-Code angezeigt hat."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This link wants to enroll you as the founding owner of a new household. Verify the fingerprint below matches the one shown on the Mac that displayed the QR."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este enlace quiere registrarte como propietario fundador de una nueva casa. Verifica que la huella de abajo coincida con la que se muestra en el Mac que mostró el QR."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce lien veut vous inscrire comme propriétaire fondateur d’une nouvelle maison. Vérifiez que l’empreinte ci-dessous correspond à celle affichée sur le Mac qui a montré le QR."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह link आपको नए home के founding owner के रूप में enroll करना चाहता है। नीचे का fingerprint उस Mac पर दिखे fingerprint से match करें जिसने QR दिखाया था।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tautan ini akan mendaftarkan Anda sebagai pemilik pendiri rumah baru. Pastikan fingerprint di bawah cocok dengan yang ditampilkan di Mac yang menampilkan QR."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このリンクは、新しい家の最初の所有者として登録しようとしています。下のフィンガープリントが、QR を表示した Mac に表示されているものと一致することを確認してください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "이 링크는 새 홈의 최초 소유자로 등록하려고 합니다. 아래 지문이 QR을 표시한 Mac에 보이는 것과 일치하는지 확인하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "此链接要将你注册为新家的创始所有者。请确认下方指纹与显示 QR 的 Mac 上显示的指纹一致。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "This link wants to enroll you as the founding owner of a new household. Verify the fingerprint below matches the one shown on the Mac that displayed the QR."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este link quer cadastrar você como proprietário fundador de uma nova casa. Confira se a impressão abaixo corresponde à exibida no Mac que mostrou o QR."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta ligação quer registá-lo como proprietário fundador de uma nova casa. Confirme que a impressão abaixo corresponde à apresentada no Mac que mostrou o QR."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта ссылка регистрирует вас как первого владельца нового дома. Убедитесь, что отпечаток ниже совпадает с отпечатком на Mac, который показал QR."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "This link wants to enroll you as the founding owner of a new household. Verify the fingerprint below matches the one shown on the Mac that displayed the QR."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ link آپ کو نئے home کے founding owner کے طور پر enroll کرنا چاہتا ہے۔ نیچے کا fingerprint اس Mac پر دکھائے گئے fingerprint سے match کریں جس نے QR دکھایا تھا۔"
          }
        }
      },
      "comment": "Body text of the deep-link pair-device confirmation sheet, explaining why the user should verify the fingerprint."
    },
