        "ko": {"stringUnit": {"state": "translated", "value": "터미널의 모양과 동작을 사용자화합니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "自定义终端的外观和行为。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "टर्मिनलचा देखावा आणि वर्तन सानुकूलित करा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalize a aparência e o comportamento do terminal."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalize a aparência e o comportamento do terminal."
          }
        },
        "ru": {
