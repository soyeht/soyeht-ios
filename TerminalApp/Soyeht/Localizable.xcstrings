    "recovery.title": {
      "comment": "Recovery message title. Reassuring, positive. Period is intentional.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أخبار جيدة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Good news."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अच्छी खबर।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "良いお知らせ。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Boa notícia."
          }
        }
      }
    },
    "recovery.body": {
      "comment": "Recovery message body. Calm, non-alarming. Explains multi-device key recovery.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا فقدت يومًا جهاز iPhone، يمكن لـ Mac آخر استرداد منزلك. مفاتيحك تظل آمنة — لا تعتمد على أي جهاز بمفرده."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you ever lose your iPhone, another Mac can recover your home. Your keys stay safe — they don't depend on any single device."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगर आप कभी iPhone खो दें, तो दूसरा Mac आपका घर वापस पा सकता है। आपकी चाबियां सुरक्षित रहती हैं — वे किसी एक डिवाइस पर निर्भर नहीं हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いつかiPhoneを紛失しても、別のMacがあなたのホームを復元できます。鍵は安全に保管され、どのデバイスにも依存しません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se um dia você perder o iPhone, outro Mac pode recuperar sua casa. Suas chaves ficam seguras — não dependem de nenhum dispositivo sozinho."
          }
        }
      }
    },
    "recovery.cta": {
      "comment": "Recovery message dismiss CTA.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فهمت"
