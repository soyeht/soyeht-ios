    "howToRecover.title": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كيف يستعيد منزلك الوصول"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "How your home recovers"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "So wird Ihr Zuhause wiederhergestellt"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How your home recovers"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cómo se recupera tu casa"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comment votre maison se récupère"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका home कैसे recover होता है"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Cara rumah Anda dipulihkan"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "家を復旧する仕組み"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "홈이 복구되는 방식"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "你的家如何恢复"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "How your home recovers"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Como sua casa se recupera"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Como a sua casa se recupera"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как восстанавливается ваш дом"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "How your home recovers"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کا home کیسے recover ہوتا ہے"
          }
        }
      },
      "comment": "Settings How-to-recover screen title."
    },
    "howToRecover.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا فقدت iPhone، يمكن لجهاز Mac آخر موجود بالفعل في منزلك استعادة الوصول. مفاتيحك موزعة، لذلك لا يصبح أي جهاز منفرد نقطة فشل وحيدة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "If you lose the iPhone, another Mac that is already part of your home can recover access. Your keys are distributed, so no single device is a single point of failure."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie das iPhone verlieren, kann ein anderer Mac, der bereits Teil Ihres Zuhauses ist, den Zugriff wiederherstellen. Ihre Schlüssel sind verteilt, sodass kein einzelnes Gerät ein einzelner Ausfallpunkt ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you lose the iPhone, another Mac that is already part of your home can recover access. Your keys are distributed, so no single device is a single point of failure."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si pierdes el iPhone, otro Mac que ya forme parte de tu casa puede recuperar el acceso. Tus claves están distribuidas, así que ningún dispositivo es un punto único de fallo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous perdez l’iPhone, un autre Mac déjà membre de votre maison peut récupérer l’accès. Vos clés sont distribuées, donc aucun appareil ne constitue un point de défaillance unique."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगर iPhone खो जाए, तो आपके home का हिस्सा बना दूसरा Mac access recover कर सकता है। आपकी keys distributed हैं, इसलिए कोई single device single point of failure नहीं है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika Anda kehilangan iPhone, Mac lain yang sudah menjadi bagian dari rumah Anda dapat memulihkan akses. Kunci Anda terdistribusi, jadi tidak ada satu perangkat pun yang menjadi satu titik kegagalan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone を紛失しても、家にすでに参加している別の Mac からアクセスを復旧できます。キーは分散されているため、単一のデバイスが唯一の障害点になることはありません。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "iPhone을 잃어버려도 이미 홈에 속한 다른 Mac이 접근 권한을 복구할 수 있습니다. 키가 분산되어 있어 어떤 단일 기기도 단일 장애 지점이 되지 않습니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "如果你丢失 iPhone，另一个已经属于你的家的 Mac 可以恢复访问。你的密钥是分布式的，所以任何单一设备都不会成为单点故障。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "If you lose the iPhone, another Mac that is already part of your home can recover access. Your keys are distributed, so no single device is a single point of failure."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se você perder o iPhone, outro Mac que já faz parte da sua casa pode recuperar o acesso. Suas chaves ficam distribuídas — nenhum dispositivo é ponto único de falha."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Se perder o iPhone, outro Mac que já faz parte da sua casa pode recuperar o acesso. As suas chaves ficam distribuídas — nenhum dispositivo é ponto único de falha."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если вы потеряете iPhone, другой Mac, который уже входит в ваш дом, сможет восстановить доступ. Ваши ключи распределены, поэтому ни одно устройство не является единой точкой отказа."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "If you lose the iPhone, another Mac that is already part of your home can recover access. Your keys are distributed, so no single device is a single point of failure."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اگر iPhone گم ہو جائے، تو آپ کے home کا حصہ بنا دوسرا Mac access recover کر سکتا ہے۔ آپ کی keys distributed ہیں، اس لیے کوئی single device single point of failure نہیں ہے۔"
          }
        }
      },
      "comment": "How-to-recover body explanation."
    },
