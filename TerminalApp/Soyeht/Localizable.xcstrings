    "parkingLot.title": {
      "comment": "Parking lot screen title. Reassuring and warm. Period is intentional.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا عجلة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No rush."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
