          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Instal Soyeht di Mac Anda"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac に Soyeht をインストール"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac에 Soyeht 설치"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在你的 Mac 上安装 Soyeht"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "तुमच्या Mac वर Soyeht इंस्टॉल करा"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale o Soyeht no Mac"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale o Soyeht no Mac"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установите Soyeht на Mac"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ Mac లో Soyeht ఇన్‌స్టాల్ చేయండి"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنے Mac پر Soyeht انسٹال کریں"
          }
        }
      },
      "comment": "Mac install link screen title."
    },
    "qrFallback.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انسخ رابط Mac أو شاركه. ثم اترك هذا iPhone مفتوحًا على الشاشة التالية بينما تنهي الإعداد هناك."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac লিংক কপি বা শেয়ার করুন। তারপর সেখানে সেটআপ শেষ করার সময় এই iPhone-টি পরের স্ক্রিনে খোলা রাখুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kopieren oder teilen Sie den Mac-Link. Lassen Sie dieses iPhone dann auf dem nächsten Bildschirm geöffnet, während Sie dort die Einrichtung abschließen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy or share the Mac link. Then keep this iPhone open on the next screen while you finish setup there."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Copia o comparte el enlace para Mac. Luego mantén este iPhone abierto en la siguiente pantalla mientras terminas la configuración allí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiez ou partagez le lien Mac. Gardez ensuite cet iPhone ouvert sur l’écran suivant pendant que vous terminez la configuration sur le Mac."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac link copy या share करें। फिर वहाँ setup पूरा करते समय इस iPhone को अगली screen पर खुला रखें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Salin atau bagikan tautan Mac. Lalu biarkan iPhone ini terbuka di layar berikutnya saat Anda menyelesaikan penyiapan di sana."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac リンクをコピーまたは共有します。その後、Mac で設定を終える間、この iPhone を次の画面で開いたままにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac 링크를 복사하거나 공유하세요. 그런 다음 Mac에서 설정을 마치는 동안 이 iPhone을 다음 화면에 열어 두세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "复制或分享 Mac 链接。然后在 Mac 上完成设置时，让这台 iPhone 保持在下一个屏幕。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac link copy किंवा share करा. मग तिथे setup पूर्ण करताना हा iPhone पुढच्या screen वर उघडा ठेवा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Copie ou compartilhe o link do Mac. Depois mantenha este iPhone aberto na próxima tela enquanto termina a configuração lá."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Copie ou partilhe a ligação do Mac. Depois mantenha este iPhone aberto no próximo ecrã enquanto termina a configuração lá."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Скопируйте ссылку для Mac или поделитесь ею. Затем оставьте этот iPhone открытым на следующем экране, пока завершаете настройку на Mac."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac link ను copy లేదా share చేయండి. తర్వాత అక్కడ setup పూర్తయ్యే వరకు ఈ iPhone ను తదుపరి screen లో తెరిచి ఉంచండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac link copy یا share کریں۔ پھر وہاں setup مکمل کرتے وقت اس iPhone کو اگلی screen پر کھلا رکھیں۔"
          }
        }
      },
      "comment": "Mac install link subtitle explaining the cross-device setup timing."
    },
