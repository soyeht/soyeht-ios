    "emailReminder.heading": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سنرسل لك تذكيرًا عندما تكون بالقرب من Mac."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "We will send you a reminder when you are near your Mac."
          }
        },
