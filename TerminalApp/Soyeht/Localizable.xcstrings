    "household.pairDevice.confirm.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This link wants to enroll you as the founding owner of a new household. Verify the fingerprint below matches the one shown on the Mac that displayed the QR."
