    "settings.pairedMacs.section.trusted.description": {
      "comment": "Explanation under the trusted-Macs section.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن لأجهزة iPhone المقترنة فتح لوحات على أجهزة Mac هذه دون طلب تأكيد. أزلها هنا لقطع الوصول."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "পেয়ার করা iPhone এই Macs-এ নিশ্চিতকরণ ছাড়াই pane খুলতে পারে। অ্যাক্সেস কাটতে এখান থেকে সরান।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gekoppelte iPhones können Bereiche auf diesen Macs ohne Bestätigung öffnen. Hier entfernen, um den Zugriff zu beenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paired iPhones can open panes on these Macs without asking for confirmation. Remove here to cut access."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los iPhones emparejados pueden abrir panes en estos Macs sin pedir confirmación. Quita aquí para cortar el acceso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les iPhones appairés peuvent ouvrir des volets sur ces Macs sans confirmation. Supprimez ici pour couper l’accès."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पेयर किए गए iPhones इन Macs पर बिना पुष्टि के pane खोल सकते हैं। एक्सेस काटने के लिए यहाँ से हटाएँ।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone yang dipasangkan dapat membuka pane pada Mac ini tanpa konfirmasi. Hapus di sini untuk memutus akses."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペアリング済みの iPhone は確認なしにこれらの Mac でペインを開けます。アクセスを切るにはここで削除してください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "페어링된 iPhone은 확인 없이 이 Mac들에서 패널을 열 수 있습니다. 접근을 차단하려면 여기에서 제거하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "已配对的 iPhone 可以在这些 Mac 上无需确认地打开窗格。要断开访问，请在这里移除。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "जोडलेले iPhones या Macs वर पुष्टीविना panes उघडू शकतात. प्रवेश कापण्यासाठी येथून काढा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhones pareados podem abrir painéis nestes Macs sem pedir confirmação. Remova aqui para cortar o acesso."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhones emparelhados podem abrir painéis nestes Macs sem pedir confirmação. Remova aqui para cortar o acesso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сопряжённые iPhone могут открывать panes на этих Mac без подтверждения. Удалите здесь, чтобы закрыть доступ."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "జత చేయబడిన iPhones ఈ Mac లలో ధృవీకరణ అడగకుండా panes తెరవగలవు. యాక్సెస్‌ను కత్తిరించడానికి ఇక్కడ నుండి తొలగించండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جوڑی شدہ iPhones ان Macs پر تصدیق مانگے بغیر panes کھول سکتے ہیں۔ رسائی ختم کرنے کے لیے یہاں سے ہٹائیں۔"
          }
        }
      }
    },
