        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "প্রিসেট প্রতিটি ওয়ার্কফ্লোর জন্য অপ্টিমাইজড কী সেট প্রয়োগ করে।"
          }
