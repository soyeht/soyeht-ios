    "emailReminder.disclaimer": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رسالة واحدة فقط. لا رسائل مزعجة ولا قائمة تسويق."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Just one email. No spam, no marketing list."
