    "voice.permission.speechDenied": {
      "comment": "Shown when Speech Recognition is denied — directs user to Settings.",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم رفض التعرف على الكلام. افتح الإعدادات للتفعيل."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "স্পিচ রিকগনিশন প্রত্যাখ্যাত। সক্ষম করতে সেটিংস খুলুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spracherkennung verweigert. Öffne Einstellungen, um es zu aktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Speech recognition denied. Open Settings to enable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reconocimiento de voz denegado. Abre Ajustes para habilitarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reconnaissance vocale refusée. Ouvrez Réglages pour l’activer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वाक् पहचान अस्वीकृत। सक्षम करने के लिए सेटिंग्स खोलें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pengenalan suara ditolak. Buka Pengaturan untuk mengaktifkan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声認識が拒否されました。設定を開いて有効にしてください。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "भाषण ओळख नाकारली. सक्षम करण्यासाठी सेटिंग्ज उघडा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Reconhecimento de fala negado. Abra os Ajustes pra habilitar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Reconhecimento de fala negado. Abra as Definições para ativar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Распознавание речи запрещено. Откройте Настройки, чтобы включить."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ప్రసంగ గుర్తింపు తిరస్కరించబడింది. ప్రారంభించడానికి సెట్టింగ్‌లు తెరవండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "تقریر شناخت مسترد۔ فعال کرنے کے لیے ترتیبات کھولیں۔"
          }
        }
      }
    },
