    "carousel.card3.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انشر أي وكيل كموقع ويب يمكن لأي شخص الوصول إليه."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "যেকোনো এজেন্টকে এমন ওয়েবসাইট হিসেবে প্রকাশ করুন যেখানে যে কেউ পৌঁছাতে পারে।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Veröffentlichen Sie jeden Agenten als Website, die jeder erreichen kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Publish any agent as a website anyone can reach."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Publica cualquier agente como un sitio web al que cualquiera pueda entrar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Publiez n’importe quel agent comme un site web accessible à tous."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी भी agent को ऐसी website के रूप में publish करें जिस तक कोई भी पहुँच सके।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Publikasikan agen apa pun sebagai situs web yang bisa dijangkau siapa saja."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どのエージェントでも、誰でもアクセスできるWebサイトとして公開できます。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "어떤 에이전트든 누구나 접속할 수 있는 웹사이트로 게시하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "将任意智能体发布为任何人都能访问的网站。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "कोणताही agent अशी website म्हणून publish करा जिथे कोणीही पोहोचू शकेल."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Publique qualquer agente como um site que qualquer pessoa pode acessar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Publique qualquer agente como um site a que qualquer pessoa pode aceder."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опубликуйте любого агента как сайт, доступный каждому."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఏ agent అయినా ఎవరైనా చేరగల website గా publish చేయండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کسی بھی agent کو ایسی website کے طور پر publish کریں جس تک کوئی بھی پہنچ سکے۔"
          }
        }
      },
      "comment": "Carousel card 3 subtitle: publish agent as a website."
    },
