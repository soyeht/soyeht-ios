    "settings.pairedMacs.empty.description": {
      "comment": "Empty-state description explaining how to pair.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط على زر QR في لوحة على Mac وامسحه بالكاميرا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac-এ pane-এর QR বোতামে ট্যাপ করে ক্যামেরা দিয়ে স্ক্যান করুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie auf die QR-Taste eines Bereichs auf dem Mac und scannen Sie mit der Kamera."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap the QR button on a pane on the Mac and scan it with the camera."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca el botón QR en un panel del Mac y escanéalo con la cámara."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez le bouton QR d’un volet sur le Mac et scannez-le avec la caméra."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac पर pane के QR बटन पर टैप करें और कैमरे से स्कैन करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ketuk tombol QR di pane pada Mac dan pindai dengan kamera."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac のペインにある QR ボタンをタップし、カメラでスキャンしてください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "Mac의 패널에서 QR 버튼을 탭하고 카메라로 스캔하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "轻点 Mac 窗格上的 QR 按钮，然后用相机扫描。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac वर pane च्या QR बटणावर टॅप करा आणि कॅमेऱ्याने स्कॅन करा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque no botão QR de um painel no Mac e escaneie com a câmera."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque no botão QR de um painel no Mac e leia-o com a câmara."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите кнопку QR в pane на Mac и отсканируйте камерой."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac లో pane పై QR బటన్‌ను నొక్కి కెమెరాతో స్కాన్ చేయండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac پر pane کے QR بٹن پر ٹیپ کریں اور کیمرے سے اسکین کریں۔"
          }
        }
      }
    },
