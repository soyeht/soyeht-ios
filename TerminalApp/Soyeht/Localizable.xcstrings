    "carousel.card2.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "دعهم يتحاورون، يقسمون العمل، وينجزون المهام كفريق."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "তাদের কথা বলতে, কাজ ভাগ করতে, এবং দল হিসেবে কাজ শেষ করতে দিন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lassen Sie sie miteinander chatten, die Arbeit aufteilen und Aufgaben als Team erledigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let them chat, split the work, and get things done as a team."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deja que conversen, dividan el trabajo y completen tareas como equipo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Laissez-les échanger, se répartir le travail et avancer en équipe."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उन्हें chat करने दें, काम बाँटने दें, और team की तरह काम पूरा करने दें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Biarkan mereka mengobrol, membagi pekerjaan, dan menyelesaikannya sebagai tim."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "会話し、作業を分担し、チームとして仕事を進められます。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "서로 대화하고, 일을 나누고, 팀으로 결과를 만들게 하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "让它们聊天、分工，并像团队一样把事情完成。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "त्यांना chat करू द्या, काम वाटू द्या, आणि team म्हणून काम पूर्ण करू द्या."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deixe-os conversar, dividir o trabalho e resolver tudo como um time."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Deixe-os conversar, dividir o trabalho e concluir tarefas como uma equipa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Позвольте им общаться, делить работу и выполнять задачи как команда."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "వాళ్లు chat చేయడానికి, పనిని పంచుకోవడానికి, team లా పూర్తి చేయడానికి వీలు ఇవ్వండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "انہیں chat کرنے دیں، کام بانٹنے دیں، اور team کی طرح کام مکمل کرنے دیں۔"
          }
        }
      },
      "comment": "Carousel card 2 subtitle: describes agent collaboration."
    },
