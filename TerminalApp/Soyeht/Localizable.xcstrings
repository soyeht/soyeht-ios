    "household.pairDevice.deriveFailed": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر التحقق من رابط الاقتران. افتح ماسح QR مرة أخرى وحاول مجددًا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not verify the pairing link. Please re-open the QR scanner and try again."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Kopplungslink konnte nicht überprüft werden. Öffnen Sie den QR-Scanner erneut und versuchen Sie es wieder."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not verify the pairing link. Please re-open the QR scanner and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo verificar el enlace de emparejamiento. Vuelve a abrir el escáner QR e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de vérifier le lien d’appairage. Rouvrez le scanner QR et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pairing link verify नहीं हो सका। QR scanner फिर से खोलें और फिर कोशिश करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tautan pairing tidak dapat diverifikasi. Buka ulang pemindai QR, lalu coba lagi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペアリングリンクを確認できませんでした。QR スキャナーを開き直して、もう一度お試しください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "페어링 링크를 확인할 수 없습니다. QR 스캐너를 다시 열고 다시 시도하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "无法验证配对链接。请重新打开 QR 扫描器并重试。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not verify the pairing link. Please re-open the QR scanner and try again."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível verificar o link de pareamento. Reabra o scanner QR e tente novamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível verificar a ligação de emparelhamento. Volte a abrir o leitor de QR e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось проверить ссылку сопряжения. Откройте сканер QR заново и попробуйте снова."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not verify the pairing link. Please re-open the QR scanner and try again."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Pairing link verify نہیں ہو سکا۔ QR scanner دوبارہ کھولیں اور پھر کوشش کریں۔"
          }
        }
      },
      "comment": "User-visible error shown when a pair-device deep link arrives but the fingerprint cannot be derived (corrupted bundle or malformed URL). The deep-link path refuses to pair without a fingerprint to display because the fingerprint is the operator's only line of defence."
    },
    "household.pairDevice.confirm.title": {
      "localizations": {
