    "howToRecover.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "If you lose the iPhone, another Mac that is already part of your home can recover access. Your keys are distributed, so no single device is a single point of failure."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "If you lose the iPhone, another Mac that is already part of your home can recover access. Your keys are distributed, so no single device is a single point of failure."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie das iPhone verlieren, kann ein anderer Mac, der bereits Teil Ihres Zuhauses ist, den Zugriff wiederherstellen. Ihre Schlüssel sind verteilt, sodass kein einzelnes Gerät ein einzelner Ausfallpunkt ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you lose the iPhone, another Mac that is already part of your home can recover access. Your keys are distributed, so no single device is a single point of failure."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si pierdes el iPhone, otro Mac que ya forme parte de tu casa puede recuperar el acceso. Tus claves están distribuidas, así que ningún dispositivo es un punto único de fallo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous perdez l’iPhone, un autre Mac déjà membre de votre maison peut récupérer l’accès. Vos clés sont distribuées, donc aucun appareil ne constitue un point de défaillance unique."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "If you lose the iPhone, another Mac that is already part of your home can recover access. Your keys are distributed, so no single device is a single point of failure."
          }
        },
        "id": {
          "stringUnit": {
            "state": "needs_review",
            "value": "If you lose the iPhone, another Mac that is already part of your home can recover access. Your keys are distributed, so no single device is a single point of failure."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "If you lose the iPhone, another Mac that is already part of your home can recover access. Your keys are distributed, so no single device is a single point of failure."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "If you lose the iPhone, another Mac that is already part of your home can recover access. Your keys are distributed, so no single device is a single point of failure."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se você perder o iPhone, outro Mac que já faz parte da sua casa pode recuperar o acesso. Suas chaves ficam distribuídas — nenhum dispositivo é ponto único de falha."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Se você perder o iPhone, outro Mac que já faz parte da sua casa pode recuperar o acesso. Suas chaves ficam distribuídas — nenhum dispositivo é ponto único de falha."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
