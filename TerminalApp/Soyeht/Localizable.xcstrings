    "settings.pairedMacs.remove.message": {
      "comment": "Body of the unpair-confirmation dialog.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم حذف سرّ الاقتران. للإقران مرة أخرى، امسح رمز QR جديدًا على Mac."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "পেয়ারিং সিক্রেট মুছে ফেলা হবে। আবার পেয়ার করতে Mac-এ নতুন QR স্ক্যান করুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Kopplungsgeheimnis wird gelöscht. Um erneut zu koppeln, scannen Sie einen neuen QR auf dem Mac."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The pairing secret will be deleted. To pair again, scan a new QR on the Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se eliminará el secreto de emparejamiento. Para volver a emparejar, escanea un nuevo QR en el Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le secret d’appairage sera supprimé. Pour re-appairer, scannez un nouveau QR sur le Mac."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पेयरिंग सीक्रेट हटा दिया जाएगा। दोबारा पेयर करने के लिए Mac पर नया QR स्कैन करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Rahasia pasangan akan dihapus. Untuk memasangkan lagi, pindai QR baru di Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペアリング シークレットが削除されます。再度ペアリングするには、Mac で新しい QR をスキャンしてください。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "पेअरिंग सीक्रेट हटवला जाईल. पुन्हा जोडण्यासाठी Mac वर नवीन QR स्कॅन करा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O segredo de pareamento será apagado. Pra voltar, escaneie um novo QR no Mac."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O segredo de emparelhamento será apagado. Para voltar a emparelhar, leia um novo QR no Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Секрет сопряжения будет удалён. Чтобы снова сопрячься, отсканируйте новый QR на Mac."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "పెయిరింగ్ రహస్యం తొలగించబడుతుంది. మళ్ళీ జత చేయడానికి Mac లో కొత్త QR ను స్కాన్ చేయండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جوڑی کا راز حذف ہو جائے گا۔ دوبارہ جوڑنے کے لیے Mac پر نیا QR اسکین کریں۔"
          }
        }
      }
    },
