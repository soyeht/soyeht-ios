    "settings.pairedMacs.empty.description": {
      "comment": "Empty-state description explaining how to pair.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap the QR button on a pane on the Mac and scan it with the camera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Clique no botão QR de um pane no Mac e escaneie com a câmera."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Clique no botão QR de um pane no Mac e leia com a câmara."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca el botón QR en un pane del Mac y escanéalo con la cámara."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie auf die QR-Taste eines Panes auf dem Mac und scannen Sie mit der Kamera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez le bouton QR d’un pane sur le Mac et scannez-le avec la caméra."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите кнопку QR в pane на Mac и отсканируйте камерой."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ketuk tombol QR di pane pada Mac dan pindai dengan kamera."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط على زر QR في pane على Mac وامسحه بالكاميرا."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac پر pane کے QR بٹن پر ٹیپ کریں اور کیمرے سے اسکین کریں۔"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac の pane の QR ボタンをタップし、カメラでスキャンしてください。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac पर pane के QR बटन पर टैप करें और कैमरे से स्कैन करें।"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Mac वर pane च्या QR बटणावर टॅप करा आणि कॅमेऱ्याने स्कॅन करा."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Mac లో pane పై QR బటన్‌ను నొక్కి కెమెరాతో స్కాన్ చేయండి."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Mac-এ pane-এর QR বোতামে ট্যাপ করে ক্যামেরা দিয়ে স্ক্যান করুন।"
          }
