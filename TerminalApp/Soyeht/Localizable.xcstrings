    "settings.fontSize.description": {
      "comment": "Description under font size section.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضبط حجم الخط لتحسين القراءة. يغير cols/rows تلقائياً."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ভালো পাঠযোগ্যতার জন্য ফন্ট আকার সামঞ্জস্য করুন। cols/rows স্বয়ংক্রিয়ভাবে পরিবর্তন হয়।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passe die Schriftgröße für bessere Lesbarkeit an. Cols/Rows werden automatisch angepasst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjust the font size for better readability. Automatically changes cols/rows."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajusta el tamaño de fuente para mejor legibilidad. Cambia cols/rows automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajuste la taille de police pour une meilleure lisibilité. Change automatiquement les cols/rows."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बेहतर पठनीयता के लिए फ़ॉन्ट आकार समायोजित करें। cols/rows स्वचालित रूप से बदलेंगे।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesuaikan ukuran font untuk keterbacaan. Otomatis mengubah cols/rows."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "読みやすさのためにフォントサイズを調整してください。cols/rows は自動的に変わります。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "चांगल्या वाचनक्षमतेसाठी फॉन्ट आकार समायोजित करा. cols/rows आपोआप बदलतात."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajuste o tamanho da fonte para melhor legibilidade. Ajusta cols/rows automaticamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajuste o tamanho do tipo de letra para melhor legibilidade. Ajusta cols/rows automaticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте размер шрифта для удобства чтения. Количество cols/rows меняется автоматически."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "మెరుగైన చదవదగినంకై ఫాంట్ సైజును సర్దుబాటు చేయండి. cols/rows స్వయంచాలకంగా మారుతుంది."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "بہتر پڑھنے کے لیے فونٹ سائز ایڈجسٹ کریں۔ cols/rows خودکار طور پر تبدیل ہوں گے۔"
          }
        }
      }
    },
