    "carousel.card1.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وكيل واحد لا يكفي أبدًا. افتح Claw Store وشغّل وكلاء بلمسة واحدة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "একজন এজেন্ট কখনোই যথেষ্ট নয়। Claw Store-এ যান এবং এক ট্যাপে এজেন্ট চালু করুন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Agent reicht nie aus. Öffnen Sie Claw Store und starten Sie Agenten mit einem Fingertipp."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One agent is never enough. Visit the Claw Store and spin up agents with a single tap."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un solo agente nunca basta. Visita Claw Store y pon agentes en marcha con un solo toque."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un seul agent ne suffit jamais. Ouvrez Claw Store et lancez des agents d’un simple toucher."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक agent कभी काफी नहीं होता। Claw Store खोलें और एक tap में agents चलाएँ।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Satu agen tidak pernah cukup. Buka Claw Store dan jalankan agen dengan satu ketukan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1つのエージェントだけでは足りません。Claw Storeを開いて、ワンタップでエージェントを起動できます。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "에이전트 하나로는 충분하지 않습니다. Claw Store를 열고 한 번의 탭으로 에이전트를 실행하세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "一个智能体从来不够。打开 Claw Store，一点即可启动多个智能体。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "एक agent कधीच पुरेसा नसतो. Claw Store उघडा आणि एका tap मध्ये agents सुरू करा."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um agente nunca é suficiente. Abra a Claw Store e coloque agentes para rodar com um toque."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Um agente nunca chega. Abra a Claw Store e ponha agentes a correr com um toque."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Одного агента всегда мало. Откройте Claw Store и запускайте агентов одним касанием."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఒక agent ఎప్పుడూ సరిపోదు. Claw Store తెరిచి, ఒక tap తో agents ప్రారంభించండి."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایک agent کبھی کافی نہیں ہوتا۔ Claw Store کھولیں اور ایک tap سے agents شروع کریں۔"
          }
        }
      },
      "comment": "Carousel card 1 subtitle: describes Claw Store."
    },
