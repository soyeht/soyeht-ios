        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac に接続できません。Mac で Soyeht アプリを開いてみてください。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "Mac에 연결할 수 없습니다. Mac에서 Soyeht 앱을 열어 보세요."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "无法访问 Mac。请尝试在 Mac 上打开 Soyeht app。"}},
