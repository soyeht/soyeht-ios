            "value": "// కర్సర్ రంగు"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "// کرسر کا رنگ"
          }
        }
      }
    },
    "settings.cursorStyle.section.color.description": {
      "comment": "Description under cursor color section.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر لون المؤشر. سيتم تطبيق اللون على النمط المختار أعلاه."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "কার্সার রঙ বেছে নিন। রঙ উপরে বেছে নেওয়া শৈলীতে প্রয়োগ হবে।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle die Cursor-Farbe. Sie wird auf den oben gewählten Stil angewendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the cursor color. The color will be applied to the style chosen above."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el color del cursor. Se aplicará al estilo elegido arriba."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisis la couleur du curseur. Elle sera appliquée au style choisi ci-dessus."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कर्सर रंग चुनें। रंग ऊपर चुनी गई शैली पर लागू होगा।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih warna kursor. Warna akan diterapkan pada gaya yang dipilih di atas."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カーソルの色を選択してください。上で選択したスタイルに色が適用されます。"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "कर्सर रंग निवडा. रंग वर निवडलेल्या शैलीवर लागू केला जाईल."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha a cor do cursor. Ela será aplicada ao estilo escolhido acima."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha a cor do cursor. Será aplicada ao estilo escolhido acima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите цвет курсора. Он будет применён к выбранному выше стилю."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "కర్సర్ రంగును ఎంచుకోండి. ఎంచుకున్న శైలికి రంగు వర్తించబడుతుంది."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کرسر کا رنگ منتخب کریں۔ رنگ اوپر منتخب کردہ انداز پر لاگو ہوگا۔"
          }
        }
      }
    },
