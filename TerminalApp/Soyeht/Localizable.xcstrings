    "residentExplainer.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعني العيش أن Mac هو القاعدة الفعلية لمنزلك الرقمي. يخزن البيانات ويشغّل الوكلاء، كما أن للمنزل الحقيقي أساسًا. يمكنك الوصول إليه من أي جهاز، لكن Mac هو المركز."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wohnen bedeutet, dass Ihr Mac die physische Basis Ihres digitalen Zuhauses ist. Er speichert die Daten und führt die Agenten aus, so wie ein echtes Haus ein Fundament hat. Sie können von jedem Gerät aus zugreifen, aber der Mac ist das Zentrum."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vivir significa que tu Mac es la base física de tu casa digital. Guarda los datos y ejecuta los agentes, como una casa real tiene cimientos. Puedes acceder desde cualquier dispositivo, pero el Mac es el centro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Habiter signifie que votre Mac est la base physique de votre maison numérique. Il stocke les données et exécute les agents, comme une vraie maison repose sur des fondations. Vous pouvez y accéder depuis n’importe quel appareil, mais le Mac est le centre."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Living का मतलब है कि आपका Mac आपके digital home का physical base है। यह data store करता है और agents चलाता है, जैसे real home की नींव होती है। आप किसी भी device से access कर सकते हैं, लेकिन Mac center है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tinggal berarti Mac Anda menjadi basis fisik rumah digital Anda. Mac menyimpan data dan menjalankan agen, seperti rumah nyata memiliki fondasi. Anda dapat mengaksesnya dari perangkat apa pun, tetapi Mac adalah pusatnya."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "住むとは、Mac がデジタルな家の物理的な基盤になるということです。データを保存し、エージェントを実行します。本物の家に土台があるのと同じです。どのデバイスからでもアクセスできますが、中心は Mac です。"
          }
        },
        "ko": {"stringUnit": {"state": "translated", "value": "산다는 것은 Mac이 디지털 홈의 물리적 기반이 된다는 뜻입니다. 데이터를 저장하고 에이전트를 실행합니다. 실제 집에 기초가 있는 것과 같습니다. 어떤 기기에서든 접근할 수 있지만 중심은 Mac입니다."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "居住意味着 Mac 是你数字家园的物理基础。它保存数据并运行智能体，就像真实的家有地基一样。你可以从任何设备访问它，但 Mac 是中心。"}},
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Morar significa que seu Mac é a base física da sua casa digital. Ele armazena os dados e roda os agentes — como uma casa de verdade tem alicerces. Você acessa de qualquer dispositivo, mas o Mac é o centro."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Morar significa que o seu Mac é a base física da sua casa digital. Ele armazena os dados e executa os agentes — como uma casa de verdade tem alicerces. Pode aceder a partir de qualquer dispositivo, mas o Mac é o centro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Жить здесь значит, что ваш Mac является физической базой цифрового дома. Он хранит данные и запускает агентов, как у настоящего дома есть фундамент. Вы можете обращаться к нему с любого устройства, но Mac остается центром."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Living means your Mac is the physical base of your digital home. It stores the data and runs the agents, like a real home has foundations. You can access it from any device, but the Mac is the center."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Living کا مطلب ہے کہ آپ کا Mac آپ کے digital home کا physical base ہے۔ یہ data store کرتا ہے اور agents چلاتا ہے، جیسے real home کی foundations ہوتی ہیں۔ آپ کسی بھی device سے access کر سکتے ہیں، لیکن Mac center ہے۔"
          }
        }
      },
      "comment": "Prose explaining what 'living here' means in Soyeht. Keep warm and non-technical."
    },
