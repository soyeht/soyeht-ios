        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Nome apresentado no botão. Deixe vazio para automático."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Имя на кнопке. Оставьте пустым для авто."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "బటన్‌పై చూపబడే పేరు. ఆటో కోసం ఖాళీగా ఉంచండి."
