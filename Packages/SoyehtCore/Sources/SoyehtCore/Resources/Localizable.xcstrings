{
  "sourceLanguage": "en",
  "strings": {
    "household.pairing.error.certInvalid": {
      "comment": "Failure shown when the owner PersonCert cannot be validated.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível confiar nesta resposta de pareamento. Escaneie um QR novo e tente de novo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível confiar nesta resposta de emparelhamento. Leia um QR novo e tente novamente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo confiar en esta respuesta de emparejamiento. Escanea un QR nuevo e inténtalo de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Kopplungsantwort konnte nicht vertraut werden. Scannen Sie einen neuen QR-Code und versuchen Sie es erneut."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette réponse d’appairage n’a pas pu être vérifiée. Scannez un nouveau QR et réessayez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "id": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر الوثوق باستجابة الاقتران هذه. امسح QR جديدًا وحاول مجددًا."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このペアリング応答を信頼できませんでした。新しい QR をスキャンしてもう一度お試しください。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        }
      }
    },
    "household.pairing.error.biometryCanceled": {
      "comment": "Failure shown when biometric signing is canceled during first-owner pairing.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A confirmação biométrica foi cancelada. Tente parear de novo quando estiver pronto."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A confirmação biométrica foi cancelada. Tente emparelhar novamente quando estiver pronto."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se canceló la confirmación biométrica. Intenta emparejar de nuevo cuando estés listo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die biometrische Bestätigung wurde abgebrochen. Versuchen Sie die Kopplung erneut, wenn Sie bereit sind."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La confirmation biométrique a été annulée. Réessayez l’appairage quand vous êtes prêt."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "id": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إلغاء التأكيد الحيوي. حاول الاقتران مرة أخرى عندما تكون جاهزًا."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "生体認証の確認がキャンセルされました。準備ができたら、もう一度ペアリングしてください。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        }
      }
    },
    "household.pairing.error.cameraPermissionDenied": {
      "comment": "Failure shown when camera access is denied during household QR scanning.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso à câmera está desativado. Ative o acesso à câmera para o Soyeht e escaneie o QR de novo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso à câmara está desativado. Ative o acesso à câmara para o Soyeht e leia o QR novamente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso a la cámara está desactivado. Activa el acceso a la cámara para Soyeht y escanea el QR de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Kamerazugriff ist deaktiviert. Aktivieren Sie den Kamerazugriff für Soyeht und scannen Sie den QR-Code erneut."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’accès à la caméra est désactivé. Activez l’accès à la caméra pour Soyeht et scannez à nouveau le QR."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        },
        "id": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الوصول إلى الكاميرا معطل. فعّل وصول الكاميرا لـ Soyeht وامسح QR مرة أخرى."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラアクセスがオフです。Soyeht のカメラアクセスを有効にして、QR をもう一度スキャンしてください。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
