    "household.machineJoin.settings.applePushService.footer": {
      "comment": "Footer caption explaining the per-household Apple Push Service toggle.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, your iPhone receives join-request alerts even while Soyeht is in the background. When off, alerts arrive only while Soyeht is open."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, seu iPhone recebe alertas de solicitação de entrada mesmo com o Soyeht em segundo plano. Quando desativado, os alertas chegam apenas enquanto o Soyeht está aberto."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o seu iPhone recebe alertas de pedidos de entrada mesmo com o Soyeht em segundo plano. Quando desativado, os alertas chegam apenas enquanto o Soyeht está aberto."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, tu iPhone recibe alertas de solicitudes de unión incluso mientras Soyeht está en segundo plano. Cuando está desactivado, las alertas llegan solo mientras Soyeht está abierto."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn diese Option aktiviert ist, empfängt Ihr iPhone Beitrittsanfragen auch dann, wenn Soyeht im Hintergrund läuft. Wenn sie deaktiviert ist, kommen Warnungen nur an, während Soyeht geöffnet ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quand cette option est activée, votre iPhone reçoit les alertes de demande d’ajout même lorsque Soyeht est en arrière-plan. Quand elle est désactivée, les alertes arrivent uniquement lorsque Soyeht est ouvert."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "When on, your iPhone receives join-request alerts even while Soyeht is in the background. When off, alerts arrive only while Soyeht is open."
          }
        },
        "id": {
          "stringUnit": {
            "state": "needs_review",
            "value": "When on, your iPhone receives join-request alerts even while Soyeht is in the background. When off, alerts arrive only while Soyeht is open."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يتلقى iPhone تنبيهات طلبات الانضمام حتى عندما يكون Soyeht في الخلفية. عند التعطيل، تصل التنبيهات فقط عندما يكون Soyeht مفتوحًا."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "When on, your iPhone receives join-request alerts even while Soyeht is in the background. When off, alerts arrive only while Soyeht is open."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンにすると、Soyeht がバックグラウンドにある間も iPhone が参加リクエストの通知を受け取ります。オフにすると、通知は Soyeht が開いている間だけ届きます。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "When on, your iPhone receives join-request alerts even while Soyeht is in the background. When off, alerts arrive only while Soyeht is open."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "When on, your iPhone receives join-request alerts even while Soyeht is in the background. When off, alerts arrive only while Soyeht is open."
          }
        },
        "te": {
