    "household.pairing.error.storageFailed": {
      "comment": "Failure shown when validated household pairing state could not be stored locally.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pairing could not be saved on this iPhone. Check device security settings and try again."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível salvar o pareamento neste iPhone. Verifique os ajustes de segurança do dispositivo e tente de novo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível guardar o emparelhamento neste iPhone. Verifique as definições de segurança do dispositivo e tente novamente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo guardar el emparejamiento en este iPhone. Revisa los ajustes de seguridad del dispositivo e inténtalo de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Kopplung konnte auf diesem iPhone nicht gespeichert werden. Prüfen Sie die Sicherheitseinstellungen des Geräts und versuchen Sie es erneut."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’appairage n’a pas pu être enregistré sur cet iPhone. Vérifiez les réglages de sécurité de l’appareil, puis réessayez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось сохранить сопряжение на этом iPhone. Проверьте настройки безопасности устройства и попробуйте снова."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pairing tidak dapat disimpan di iPhone ini. Periksa pengaturan keamanan perangkat, lalu coba lagi."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر حفظ الاقتران على هذا iPhone. تحقق من إعدادات أمان الجهاز وحاول مجددًا."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pairing could not be saved on this iPhone. Check device security settings and try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone にペアリングを保存できませんでした。デバイスのセキュリティ設定を確認して、もう一度お試しください。"
