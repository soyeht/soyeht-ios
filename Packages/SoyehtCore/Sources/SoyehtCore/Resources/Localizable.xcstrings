          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
