          "stringUnit": {
            "state": "translated",
            "value": "iPhone ini tidak dapat menandatangani persetujuan bergabung. Pairing ulang perangkat pemilik ini, lalu coba lagi."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر على هذا iPhone توقيع موافقة الانضمام. أعد إقران جهاز المالك هذا وحاول مجددًا."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This iPhone could not sign the join approval. Re-pair this owner device and try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone は参加承認に署名できませんでした。この所有者デバイスを再ペアリングして、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 iPhone에서 참여 승인을 서명할 수 없습니다. 이 소유자 기기를 다시 페어링한 뒤 다시 시도하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 iPhone 无法签署加入批准。请重新配对此所有者设备后重试。"
          }
        },
        "hi": {
