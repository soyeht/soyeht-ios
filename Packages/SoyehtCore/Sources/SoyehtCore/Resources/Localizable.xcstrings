{
  "sourceLanguage": "en",
  "strings": {
    "household.pairing.error.certInvalid": {
      "comment": "Failure shown when the owner PersonCert cannot be validated.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível confiar nesta resposta de pareamento. Escaneie um QR novo e tente de novo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível confiar nesta resposta de emparelhamento. Leia um QR novo e tente novamente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo confiar en esta respuesta de emparejamiento. Escanea un QR nuevo e inténtalo de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Kopplungsantwort konnte nicht vertraut werden. Scannen Sie einen neuen QR-Code und versuchen Sie es erneut."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette réponse d’appairage n’a pas pu être vérifiée. Scannez un nouveau QR et réessayez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этому ответу на сопряжение нельзя доверять. Отсканируйте новый QR и попробуйте снова."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Respons pairing ini tidak dapat dipercaya. Pindai QR baru dan coba lagi."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر الوثوق باستجابة الاقتران هذه. امسح QR جديدًا وحاول مجددًا."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このペアリング応答を信頼できませんでした。新しい QR をスキャンしてもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 페어링 응답을 신뢰할 수 없습니다. 새 QR을 스캔한 뒤 다시 시도하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法信任此配对响应。请扫描新的 QR 后重试。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing response could not be trusted. Scan a fresh QR and try again."
          }
        }
      }
    },
    "household.pairing.error.biometryCanceled": {
      "comment": "Failure shown when biometric signing is canceled during first-owner pairing.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A confirmação biométrica foi cancelada. Tente parear de novo quando estiver pronto."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A confirmação biométrica foi cancelada. Tente emparelhar novamente quando estiver pronto."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se canceló la confirmación biométrica. Intenta emparejar de nuevo cuando estés listo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die biometrische Bestätigung wurde abgebrochen. Versuchen Sie die Kopplung erneut, wenn Sie bereit sind."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La confirmation biométrique a été annulée. Réessayez l’appairage quand vous êtes prêt."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Биометрическое подтверждение отменено. Попробуйте выполнить сопряжение снова, когда будете готовы."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfirmasi biometrik dibatalkan. Coba pairing lagi saat Anda siap."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إلغاء التأكيد الحيوي. حاول الاقتران مرة أخرى عندما تكون جاهزًا."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "生体認証の確認がキャンセルされました。準備ができたら、もう一度ペアリングしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "생체 인증 확인이 취소되었습니다. 준비되면 다시 페어링하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "生物识别确认已取消。准备好后请重新配对。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Biometric confirmation was canceled. Try pairing again when you are ready."
          }
        }
      }
    },
    "household.pairing.error.cameraPermissionDenied": {
      "comment": "Failure shown when camera access is denied during household QR scanning.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso à câmera está desativado. Ative o acesso à câmera para o Soyeht e escaneie o QR de novo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso à câmara está desativado. Ative o acesso à câmara para o Soyeht e leia o QR novamente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso a la cámara está desactivado. Activa el acceso a la cámara para Soyeht y escanea el QR de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Kamerazugriff ist deaktiviert. Aktivieren Sie den Kamerazugriff für Soyeht und scannen Sie den QR-Code erneut."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’accès à la caméra est désactivé. Activez l’accès à la caméra pour Soyeht et scannez à nouveau le QR."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к камере отключен. Разрешите Soyeht доступ к камере и отсканируйте QR снова."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses kamera tidak aktif. Aktifkan akses kamera untuk Soyeht, lalu pindai QR lagi."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الوصول إلى الكاميرا معطل. فعّل وصول الكاميرا لـ Soyeht وامسح QR مرة أخرى."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラアクセスがオフです。Soyeht のカメラアクセスを有効にして、QR をもう一度スキャンしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "카메라 접근이 꺼져 있습니다. Soyeht의 카메라 접근을 켠 뒤 QR을 다시 스캔하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "相机访问已关闭。请为 Soyeht 启用相机访问，然后重新扫描 QR。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Camera access is off. Enable camera access for Soyeht and scan the QR again."
          }
        }
      }
    },
    "household.pairing.error.expiredQR": {
      "comment": "Failure shown when the scanned first-owner household QR has expired.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This pairing code expired. Create a fresh QR on the Mac and scan it again."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este código de pareamento expirou. Crie um QR novo no Mac e escaneie de novo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Este código de emparelhamento expirou. Crie um QR novo no Mac e leia-o novamente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este código de emparejamiento caducó. Crea un QR nuevo en el Mac y escanéalo de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Kopplungscode ist abgelaufen. Erstellen Sie auf dem Mac einen neuen QR-Code und scannen Sie ihn erneut."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce code d’appairage a expiré. Créez un nouveau QR sur le Mac et scannez-le à nouveau."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Срок действия этого кода сопряжения истек. Создайте новый QR на Mac и отсканируйте его снова."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kode pairing ini sudah kedaluwarsa. Buat QR baru di Mac, lalu pindai lagi."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انتهت صلاحية رمز الاقتران هذا. أنشئ QR جديدًا على Mac وامسحه مرة أخرى."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing code expired. Create a fresh QR on the Mac and scan it again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このペアリングコードは期限切れです。Mac で新しい QR を作成して、もう一度スキャンしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 페어링 코드가 만료되었습니다. Mac에서 새 QR을 만든 뒤 다시 스캔하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此配对码已过期。请在 Mac 上创建新的 QR 并重新扫描。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing code expired. Create a fresh QR on the Mac and scan it again."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing code expired. Create a fresh QR on the Mac and scan it again."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing code expired. Create a fresh QR on the Mac and scan it again."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This pairing code expired. Create a fresh QR on the Mac and scan it again."
          }
        }
      }
    },
    "household.pairing.error.firstOwnerAlreadyPaired": {
      "comment": "Failure shown when theyOS reports that the first owner has already been paired.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This house already has its first owner device. Use a fresh install-time pairing code."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta casa já tem seu primeiro dispositivo proprietário. Use um novo código de pareamento da instalação."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta casa já tem o primeiro dispositivo proprietário. Use um novo código de emparelhamento da instalação."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta casa ya tiene su primer dispositivo propietario. Usa un código de emparejamiento de instalación nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Zuhause hat bereits sein erstes Eigentümergerät. Verwenden Sie einen neuen Kopplungscode aus der Installation."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette maison possède déjà son premier appareil propriétaire. Utilisez un nouveau code d’appairage d’installation."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У этого дома уже есть первое устройство владельца. Используйте новый код сопряжения из установки."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Rumah ini sudah memiliki perangkat pemilik pertama. Gunakan kode pairing baru dari proses instalasi."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لهذا المنزل جهاز مالك أول بالفعل. استخدم رمز اقتران تثبيت جديدًا."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This house already has its first owner device. Use a fresh install-time pairing code."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この家には既に最初の所有者デバイスがあります。インストール時の新しいペアリングコードを使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 집에는 이미 첫 번째 소유자 기기가 있습니다. 설치 시 생성된 새 페어링 코드를 사용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这个家已经有第一台所有者设备。请使用安装时生成的新配对码。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This house already has its first owner device. Use a fresh install-time pairing code."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This house already has its first owner device. Use a fresh install-time pairing code."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This house already has its first owner device. Use a fresh install-time pairing code."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This house already has its first owner device. Use a fresh install-time pairing code."
          }
        }
      }
    },
    "household.pairing.error.identityKeyUnavailable": {
      "comment": "Failure shown when the Secure Enclave owner identity key cannot be created or loaded.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This iPhone could not create the owner identity key. Check Face ID or device security settings and try again."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este iPhone não conseguiu criar a chave de identidade do proprietário. Verifique o Face ID ou os ajustes de segurança do dispositivo e tente de novo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Este iPhone não conseguiu criar a chave de identidade do proprietário. Verifique o Face ID ou as definições de segurança do dispositivo e tente novamente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este iPhone no pudo crear la clave de identidad del propietario. Revisa Face ID o los ajustes de seguridad del dispositivo e inténtalo de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses iPhone konnte den Identitätsschlüssel des Eigentümers nicht erstellen. Prüfen Sie Face ID oder die Sicherheitseinstellungen des Geräts und versuchen Sie es erneut."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet iPhone n’a pas pu créer la clé d’identité du propriétaire. Vérifiez Face ID ou les réglages de sécurité de l’appareil, puis réessayez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот iPhone не смог создать ключ идентификации владельца. Проверьте Face ID или настройки безопасности устройства и попробуйте снова."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone ini tidak dapat membuat kunci identitas pemilik. Periksa Face ID atau pengaturan keamanan perangkat, lalu coba lagi."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر على هذا iPhone إنشاء مفتاح هوية المالك. تحقق من Face ID أو إعدادات أمان الجهاز وحاول مجددًا."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This iPhone could not create the owner identity key. Check Face ID or device security settings and try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone で所有者 ID キーを作成できませんでした。Face ID またはデバイスのセキュリティ設定を確認して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 iPhone에서 소유자 신원 키를 만들 수 없습니다. Face ID 또는 기기 보안 설정을 확인한 뒤 다시 시도하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 iPhone 无法创建所有者身份密钥。请检查 Face ID 或设备安全设置后重试。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This iPhone could not create the owner identity key. Check Face ID or device security settings and try again."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This iPhone could not create the owner identity key. Check Face ID or device security settings and try again."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This iPhone could not create the owner identity key. Check Face ID or device security settings and try again."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This iPhone could not create the owner identity key. Check Face ID or device security settings and try again."
          }
        }
      }
    },
    "household.pairing.error.invalidQR": {
      "comment": "Failure shown when a scanned household pairing QR is malformed or unsupported.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is not a valid pairing code."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este não é um código de pareamento válido."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Este não é um código de emparelhamento válido."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este no es un código de emparejamiento válido."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies ist kein gültiger Kopplungscode."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce code d’appairage n’est pas valide."
          }
        },
        "ru": {
