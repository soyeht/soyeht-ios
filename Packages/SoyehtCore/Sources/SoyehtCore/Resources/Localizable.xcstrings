    "household.pairing.error.noMatchingHousehold": {
      "comment": "Failure shown when the app cannot find the matching theyOS household service on the local network.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your house was not found on this network. Join the same Wi-Fi and try again."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua casa não foi encontrada nesta rede. Entre na mesma rede Wi-Fi e tente de novo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A sua casa não foi encontrada nesta rede. Ligue-se à mesma rede Wi-Fi e tente novamente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se encontró tu casa en esta red. Conéctate a la misma red Wi-Fi e inténtalo de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Zuhause wurde in diesem Netzwerk nicht gefunden. Verbinden Sie sich mit demselben WLAN und versuchen Sie es erneut."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre maison est introuvable sur ce réseau. Rejoignez le même réseau Wi-Fi et réessayez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваш дом не найден в этой сети. Подключитесь к той же Wi‑Fi и попробуйте снова."
