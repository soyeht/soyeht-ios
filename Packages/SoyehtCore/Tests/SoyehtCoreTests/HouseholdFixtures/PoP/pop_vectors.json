{
  "contract": "soyeht-pop-cbor-cross-language",
  "version": 1,
  "about": [
    "Cross-language golden vectors for the Soyeht proof-of-possession (PoP) request",
    "signing context. They pin, byte-for-byte, what both theyos (Rust) and",
    "soyeht-ios (Swift) MUST produce so a PoP signature made on one side verifies on",
    "the other. The iOS half (PR2) asserts HouseholdCBOR.requestSigningContext(...)",
    "reproduces the same canonical_cbor_hex and verifies the same verify_vector."
  ],
  "format": {
    "signed_context_fields": ["v", "method", "path_and_query", "timestamp", "body_hash"],
    "canonical_cbor": "RFC 8949 4.2.1 deterministic map encoding (keys ordered by their encoded bytes, i.e. length-first then lexicographic).",
    "method": "ASCII-uppercased before signing.",
    "body_hash": "BLAKE3(body), 32 bytes, encoded as a CBOR byte string.",
    "operation_caveat_note": "Operation/caveat is NOT part of the signed request context. It is enforced separately by the cert caveats (see the P7-A household PoP/Operation gate-completeness guard). Do not add it here.",
    "verify_vector": "public_key_sec1_compressed_hex is a 33-byte SEC1 compressed P-256 public key; signature_p256_raw_hex is the 64-byte raw r||s ECDSA signature over the canonical_cbor bytes. No private key/secret appears in this fixture."
  },
  "request_signing_context": [
