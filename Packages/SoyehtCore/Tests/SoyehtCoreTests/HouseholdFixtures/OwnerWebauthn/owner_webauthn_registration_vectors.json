{
  "contract": "soyeht-owner-webauthn-registration-cbor-cross-language",
  "version": 1,
  "about": [
    "Cross-language golden vectors for owner passkey registration wire CBOR.",
    "StartRequest vectors pin the canonical CBOR body signed by Soyeht-PoP.",
    "StartResponse vectors pin Swift decode of webauthn-rs CreationChallengeResponse.",
    "FinishRequest vectors pin Swift canonical-CBOR encode before server byte-equality checks.",
    "FinishResponse vectors pin Swift decode of the successful registration response.",
    "RegistrationReject vectors pin the anti-oracle generic failure envelope."
  ],
  "format": {
    "base64_url_safe_data": "Base64UrlSafeData serializes as base64url text, even in CBOR; it accepts byte strings on decode but canonical re-encode emits text.",
    "canonical_cbor": "RFC 8949 deterministic map encoding via household_rs::cbor.",
    "finish_request_strictness": "The server decodes FinishRequest, re-encodes canonical CBOR, and rejects if bytes differ.",
    "finish_response_credential_id": "FinishResponse.credential_id is serde_bytes/ByteBuf and serializes as a CBOR byte string, not base64url text.",
    "registration_reject": "Registration start/finish failures are intentionally anti-oracle: HTTP 401 with body {v:1,error:\"unauthenticated\"}; internal reasons are tracing-only.",
    "finish_traps": [
      "RegisterPublicKeyCredential.response.transports None is encoded as null because the field has no skip_serializing_if.",
      "RegisterPublicKeyCredential.extensions is always present; the default value encodes as an empty map."
    ],
    "webauthn_keys": "Embedded webauthn-rs-proto fields use their serde wire names, mostly camelCase.",
    "wrapper_keys": "Soyeht wrapper fields use snake_case except version renamed to v."
  },
