{
  "contract": "soyeht-owner-approval-v2-wire-cbor-cross-language",
  "version": 1,
  "about": [
    "Cross-language golden vectors for owner approval Protocol-v2 WebAuthn wire wrappers.",
    "These vectors extend the existing ownerApprovalContextV2 fixture by pinning the",
    "OwnerApprovalV2 assertion envelope, the OwnerApprovalV2Finish request wrapper,",
    "and the OwnerApprovalV2StartResponse WebAuthn options wrapper used by server-rs.",
    "If these bytes change, the Swift and Rust wire contract changed intentionally."
  ],
  "format": {
    "canonical_cbor": "RFC 8949 deterministic map encoding via household_rs::cbor.",
    "context": "The embedded context uses the existing ownerApprovalContextV2 pair-machine shape plus the dedicated RevokeCredential, ProvisionRecoveryCode, AddCredential, and RecoverCredential shapes.",
    "owner_approval_v2_byte_string_fields": [
      "credential_id",
      "authenticator_data",
      "client_data_json",
      "signature",
      "user_handle"
    ],
    "context_byte_string_fields": [
      "nonce",
      "join_request_hash",
      "replay_nonce",
      "target_credential_id",
      "authority_head_hash",
      "recovery_head_hash",
      "new_credential_binding_hash"
    ],
    "revoke_credential_context": "target_credential_id is CBOR bytes even when the bytes look like base64url text; authority_head_hash is exactly 32 CBOR bytes; authority_head_sequence and pre_active_credential_count are canonical CBOR unsigned integers.",
    "provision_recovery_code_context": "authority_head_hash and recovery_head_hash are exactly 32 CBOR bytes; recovery_head_sequence/recovery_head_hash are omitted together when there is no anchored recovery head; authority_head_sequence, recovery_head_sequence, and pre_active_credential_count are canonical CBOR unsigned integers.",
    "add_credential_context": "new_credential_binding_hash and authority_head_hash are exactly 32 CBOR bytes; authority_head_sequence and pre_active_credential_count are canonical CBOR unsigned integers; the actor credential is intentionally omitted and comes from the owner approval assertion.",
    "recover_credential_context": "new_credential_binding_hash, authority_head_hash, and recovery_head_hash are exactly 32 CBOR bytes; authority_head_sequence, recovery_head_sequence, and pre_active_credential_count are canonical CBOR unsigned integers; pre_active_credential_count is telemetry and MAY be zero for break-glass recovery.",
    "webauthn_base64url_text_fields": [
      "options.publicKey.challenge",
      "options.publicKey.allowCredentials[].id"
    ],
    "user_handle": "When absent, user_handle is omitted from OwnerApprovalV2; it is never encoded as null."
  },
