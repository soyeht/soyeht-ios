  "contract": "soyeht-owner-approval-v2-cbor-cross-language",
  "version": 1,
  "about": [
    "Cross-language golden vectors for owner approval Protocol-v2 contexts.",
    "They pin the RFC 8949 deterministic CBOR bytes and SHA-256 challenge",
    "digest used by WebAuthn owner assertions. The Swift side must reproduce",
    "the same canonical_cbor_hex and challenge_sha256_hex values byte-for-byte."
  ],
  "format": {
    "challenge_domain_ascii_nul": "soyeht-owner-approval-v2\\0",
    "challenge_sha256_hex": "SHA-256(challenge_domain_ascii_nul || canonical_cbor_bytes)",
    "execution_hash_domain_ascii_nul": "soyeht-mobile-claw-vpn-dev-e2e-execution-v1\\0",
    "execution_sha256_hex": "SHA-256(execution_hash_domain_ascii_nul || canonical execution tuple CBOR bytes)",
    "canonical_cbor": "RFC 8949 4.2.1 deterministic map encoding; text keys are ordered by their encoded bytes.",
    "none_fields": "Optional fields are omitted, never encoded as null.",
    "byte_fields": ["nonce", "join_request_hash", "replay_nonce", "mobile_claw_vpn_execution_hash"],
    "owner_operation": "kebab-case string with fixed mapping; do not let language-default enum encoding choose wire names."
  },
