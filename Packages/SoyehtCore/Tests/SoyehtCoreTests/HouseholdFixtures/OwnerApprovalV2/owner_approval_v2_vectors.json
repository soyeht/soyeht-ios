{
  "contract": "soyeht-owner-approval-v2-cbor-cross-language",
  "version": 1,
  "about": [
    "Cross-language golden vectors for owner approval Protocol-v2 contexts.",
    "They pin the RFC 8949 deterministic CBOR bytes and SHA-256 challenge",
    "digest used by WebAuthn owner assertions. The Swift side must reproduce",
    "the same canonical_cbor_hex and challenge_sha256_hex values byte-for-byte."
  ],
  "format": {
    "challenge_domain_ascii_nul": "soyeht-owner-approval-v2\\0",
    "challenge_sha256_hex": "SHA-256(challenge_domain_ascii_nul || canonical_cbor_bytes)",
    "canonical_cbor": "RFC 8949 4.2.1 deterministic map encoding; text keys are ordered by their encoded bytes.",
    "none_fields": "Optional fields are omitted, never encoded as null.",
    "byte_fields": ["nonce", "join_request_hash", "replay_nonce"],
    "owner_operation": "kebab-case string with fixed mapping; do not let language-default enum encoding choose wire names."
  },
  "owner_approval_context_v2": [
    {
      "id": "pair_machine_approve_lan",
      "input": {
        "v": 2,
        "purpose": "owner-approval-v2",
        "op": "pair-machine-approve",
        "hh_id": "hh_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "owner_p_id": "p_owner-alpha",
        "cursor": 7,
        "m_id": "m_bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
        "addr": "192.0.2.10:8091",
        "transport": "lan",
        "ttl_unix": 1800,
        "nonce_hex": "1111111111111111111111111111111111111111111111111111111111111111",
        "join_request_hash_hex": "2222222222222222222222222222222222222222222222222222222222222222",
        "capabilities": ["machine-cert", "shamir-2pc"],
        "issued_at": 1000,
        "expires_at": 1600,
        "replay_nonce_hex": "3333333333333333333333333333333333333333333333333333333333333333"
      },
      "canonical_cbor_hex": "",
      "challenge_sha256_hex": "c63baf8d42fa3e6b26e40cb1289770b80c836cb95c4f6d122208ccb1a967ca7a"
    },
    {
      "id": "bootstrap_teardown_omits_optional_fields",
      "input": {
        "v": 2,
        "purpose": "owner-approval-v2",
        "op": "bootstrap-teardown",
        "hh_id": "hh_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "owner_p_id": "p_owner-alpha",
        "capabilities": [],
        "issued_at": 1000,
        "expires_at": 1100,
        "replay_nonce_hex": "7777777777777777777777777777777777777777777777777777777777777777"
      },
      "canonical_cbor_hex": "",
      "challenge_sha256_hex": "bc5c8c1f7fcf4095c712bad6e25814686eedda3821581a9071d1f9981f7bb925",
      "omitted_fields": ["cursor", "m_id", "addr", "transport", "ttl_unix", "nonce", "join_request_hash"]
    }
  ]
}
